{
  "version": "2.0.0",
  "terroir": "saas-dashboard",
  "vintage": {
    "style": "auradecantism",
    "mode": "dark",
    "recipe": "auradecantism",
    "shape": "rounded"
  },
  "character": ["professional", "data-rich", "luminous"],
  "vessel": {
    "type": "spa",
    "routing": "hash"
  },
  "structure": [
    {
      "id": "overview",
      "skeleton": "sidebar-main",
      "blend": [
        "kpi-grid",
        "quick-actions",
        { "cols": ["chart-grid", "activity-feed"], "span": { "chart-grid": 2 }, "at": "lg" }
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "analytics",
      "skeleton": "sidebar-main",
      "blend": [
        "filter-bar",
        "kpi-grid",
        "chart-grid",
        { "cols": ["comparison-panel", "data-table"], "at": "lg" }
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "users",
      "skeleton": "sidebar-main",
      "blend": [
        "kpi-grid",
        { "pattern": "filter-bar", "preset": "toolbar", "as": "users-toolbar" },
        "data-table"
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "user-detail",
      "skeleton": "sidebar-main",
      "blend": [
        { "pattern": "detail-header", "preset": "profile", "as": "user-header" },
        "kpi-grid",
        { "cols": ["timeline", "activity-feed"], "at": "lg" }
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "teams",
      "skeleton": "sidebar-main",
      "blend": [
        "filter-bar",
        { "pattern": "card-grid", "preset": "user", "as": "team-grid" },
        "data-table"
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "pipeline",
      "skeleton": "sidebar-main",
      "blend": [
        "filter-bar",
        "kanban-board"
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "billing",
      "skeleton": "sidebar-main",
      "blend": [
        "kpi-grid",
        "pricing-table",
        "order-history"
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "notifications",
      "skeleton": "sidebar-main",
      "blend": ["inbox"],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "reports",
      "skeleton": "sidebar-main",
      "blend": [
        "filter-bar",
        "chart-grid",
        "scorecard",
        "data-table"
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "changelog",
      "skeleton": "sidebar-main",
      "blend": ["changelog"],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "status",
      "skeleton": "sidebar-main",
      "blend": ["status-board"],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "settings",
      "skeleton": "sidebar-main",
      "blend": [
        { "pattern": "form-sections", "preset": "settings", "as": "settings-form" }
      ],
      "surface": "_flex _col _gap4 _p6 _overflow[auto] _flex1"
    },
    {
      "id": "login",
      "skeleton": "centered",
      "blend": ["auth-form"],
      "surface": "_flex _col _center _hfull"
    },
    {
      "id": "not-found",
      "skeleton": "full-bleed",
      "blend": [],
      "surface": "_flex _col _center _hfull"
    }
  ],
  "tannins": ["auth", "analytics-state", "search", "notifications", "user-management", "billing"],
  "cork": {
    "enforce_style": true,
    "enforce_recipe": true
  }
}
