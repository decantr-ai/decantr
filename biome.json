{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "packages/**/*.{ts,tsx,js,jsx,mjs,cjs}",
      "!**/dist/**",
      "!**/node_modules/**",
      "!**/*.d.ts",
      "!packages/cli/src/bundled/**",
      "!packages/*/decantr.essence.json",
      "!packages/*/.decantr/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "off",
        "useTemplate": "off",
        "noParameterAssign": "off",
        "useImportType": "warn",
        "useExportType": "warn",
        "useConst": "warn"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noCommentText": "off",
        "noAssignInExpressions": "warn",
        "noThenProperty": "error",
        "useIterableCallbackReturn": "error",
        "noImplicitAnyLet": "warn"
      },
      "complexity": {
        "noBannedTypes": "warn",
        "useOptionalChain": "warn"
      },
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "off"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
