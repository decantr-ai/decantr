{
  "version": "1.0.0",
  "terroir": "portfolio",
  "vintage": { "style": "auradecantism", "mode": "dark", "recipe": "auradecantism", "shape": "pill" },
  "character": ["bold", "technical", "dramatic"],
  "vessel": { "type": "spa", "routing": "hash" },
  "structure": [
    {
      "id": "home",
      "skeleton": "full-bleed",
      "blend": [
        "announcement-bar",
        { "pattern": "hero", "preset": "split", "as": "brand-hero" },
        { "pattern": "logo-strip", "preset": "marquee", "as": "partner-logos" },
        { "pattern": "card-grid", "preset": "icon", "as": "feature-grid" },
        { "pattern": "code-preview", "preset": "split", "as": "quickstart" },
        { "pattern": "stats-section", "preset": "hero", "as": "metrics" },
        { "pattern": "testimonials", "preset": "wall", "as": "social-proof" },
        "showcase-gallery",
        { "pattern": "cta-section", "preset": "brand", "as": "final-cta" },
        "footer-columns"
      ],
      "surface": "_flex _col _gap0 _overflow[auto] _flex1"
    },
    {
      "id": "docs-home",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "tutorial",
      "path": "/docs/tutorial/:step",
      "skeleton": "sidebar-main",
      "blend": ["detail-header"]
    },
    {
      "id": "cookbook",
      "path": "/docs/cookbook/:recipe",
      "skeleton": "sidebar-main",
      "blend": ["detail-header"]
    },
    {
      "id": "explorer-page",
      "path": "/explorer",
      "skeleton": "sidebar-main",
      "blend": ["component-showcase"],
      "surface": "_flex _col _overflow[auto] _flex1"
    },
    {
      "id": "gallery",
      "path": "/gallery",
      "skeleton": "full-bleed",
      "blend": [{ "pattern": "card-grid", "preset": "content", "as": "showcase-gallery" }]
    }
  ],
  "tannins": [],
  "cork": { "enforce_style": true, "enforce_recipe": true }
}
