{
  "version": "1.0.0",
  "terroir": "portfolio",
  "vintage": { "style": "auradecantism", "mode": "dark", "recipe": "auradecantism", "shape": "rounded" },
  "character": ["bold", "technical", "dramatic"],
  "vessel": { "type": "spa", "routing": "hash" },
  "structure": [
    {
      "id": "home",
      "skeleton": "full-bleed",
      "blend": ["hero", "gallery", "cta-section"],
      "surface": "_flex _col _overflow[auto] _flex1"
    },
    {
      "id": "docs-home",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "tutorial",
      "path": "/docs/tutorial/:step",
      "skeleton": "sidebar-main",
      "blend": ["detail-header"]
    },
    {
      "id": "cookbook",
      "path": "/docs/cookbook/:recipe",
      "skeleton": "sidebar-main",
      "blend": ["detail-header"]
    },
    {
      "id": "explorer-page",
      "path": "/explorer",
      "skeleton": "sidebar-main",
      "blend": ["component-showcase"],
      "surface": "_flex _col _overflow[auto] _flex1"
    },
    {
      "id": "gallery",
      "path": "/gallery",
      "skeleton": "full-bleed",
      "blend": [{ "pattern": "card-grid", "preset": "content", "as": "showcase-gallery" }]
    }
  ],
  "tannins": [],
  "cork": { "enforce_style": true, "enforce_recipe": true }
}
