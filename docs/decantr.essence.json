{
  "version": "1.0.0",
  "terroir": "portfolio",
  "vintage": { "style": "auradecantism", "mode": "dark", "recipe": "auradecantism", "shape": "rounded" },
  "character": ["bold", "technical", "dramatic"],
  "vessel": { "type": "spa", "routing": "hash" },
  "structure": [
    {
      "id": "home",
      "skeleton": "full-bleed",
      "blend": ["hero"]
    },
    {
      "id": "docs-home",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "tutorial",
      "path": "/docs/tutorial/:step",
      "skeleton": "sidebar-main",
      "blend": ["detail-header"]
    },
    {
      "id": "cookbook",
      "path": "/docs/cookbook/:recipe",
      "skeleton": "sidebar-main",
      "blend": ["detail-header"]
    },
    {
      "id": "gallery",
      "path": "/docs/components",
      "skeleton": "sidebar-main",
      "blend": [{ "pattern": "card-grid", "preset": "content", "as": "component-gallery" }]
    },
    {
      "id": "explorer",
      "path": "/docs/:section",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-patterns",
      "path": "/docs/patterns",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-icons",
      "path": "/docs/icons",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-tokens",
      "path": "/docs/tokens",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-foundations",
      "path": "/docs/foundations",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-archetypes",
      "path": "/docs/archetypes",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-charts",
      "path": "/docs/charts",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-shells",
      "path": "/docs/shells",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-recipes",
      "path": "/docs/recipes",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "explorer-tools",
      "path": "/docs/tools",
      "skeleton": "sidebar-main",
      "blend": ["card-grid"]
    },
    {
      "id": "workbench",
      "path": "/workbench",
      "skeleton": "sidebar-main",
      "blend": ["component-showcase"],
      "surface": "_flex _col _overflow[auto] _flex1"
    }
  ],
  "tannins": [],
  "cork": { "enforce_style": true, "enforce_recipe": true }
}
