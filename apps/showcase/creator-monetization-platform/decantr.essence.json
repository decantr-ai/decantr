{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "studio",
      "mode": "light",
      "shape": "rounded"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "rounded",
      "base": 8
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "subtle",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Warm, creator-first monetization platform that celebrates creative work. Light theme with soft gradients and rounded cards. Creator profiles are visually rich — large cover images, prominent avatars, and tier cards with benefit previews. Earnings dashboards use approachable chart styles (rounded bars, smooth lines) in warm accent tones. The fan storefront feels like a boutique, not a marketplace. Premium tiers get subtle visual elevation. Think Patreon meets Gumroad with a Dribbble-level polish."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "creator-dashboard",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "earnings-kpis",
          "activity-feed",
          "quick-actions"
        ],
        "description": "Creator admin dashboard home with earnings summary, recent activity, and quick actions.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "notifications",
              "stats-overview",
              "earnings-dashboard",
              "content-calendar",
              "activity-feed"
            ],
            "route": "/dashboard"
          }
        ]
      },
      {
        "id": "creator-earnings",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "revenue-charts",
          "tier-breakdown",
          "payout-configuration",
          "export-reports"
        ],
        "description": "Revenue analytics and payout management for creators. Full earnings dashboard and payout configuration.",
        "pages": [
          {
            "id": "earnings",
            "layout": [
              "earnings-dashboard",
              "payout-settings"
            ],
            "route": "/dashboard/earnings"
          },
          {
            "id": "payouts",
            "layout": [
              "payout-settings"
            ],
            "route": "/settings/payouts"
          }
        ]
      },
      {
        "id": "creator-content",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "media-upload",
          "tier-gating",
          "scheduling",
          "drafts"
        ],
        "description": "Content management for creators. Upload, organize, and manage posts, media, and products.",
        "pages": [
          {
            "id": "content",
            "layout": [
              "filters",
              "content-list"
            ],
            "route": "/dashboard/content"
          },
          {
            "id": "new",
            "layout": [
              "content-uploader",
              "post-form"
            ],
            "route": "/dashboard/content/new"
          },
          {
            "id": "edit",
            "layout": [
              "media-preview",
              "edit-form"
            ],
            "route": "/dashboard/content/:id/edit"
          }
        ]
      },
      {
        "id": "creator-subscribers",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "subscriber-filtering",
          "export-csv",
          "messaging",
          "tier-management"
        ],
        "description": "Fan and subscriber management for creators. View, filter, and engage with your audience.",
        "pages": [
          {
            "id": "subscribers",
            "layout": [
              "subscriber-list"
            ],
            "route": "/dashboard/subscribers"
          },
          {
            "id": "subscriber-detail",
            "layout": [
              "detail-header",
              "activity-feed"
            ],
            "route": "/dashboard/subscribers/:id"
          }
        ]
      },
      {
        "id": "creator-tiers",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "tier-creation",
          "benefit-management",
          "pricing-config",
          "tier-reorder"
        ],
        "description": "Subscription tier management for creators. Create, edit, and organize membership tiers.",
        "pages": [
          {
            "id": "tiers",
            "layout": [
              "tier-builder"
            ],
            "route": "/dashboard/tiers"
          }
        ]
      },
      {
        "id": "fan-storefront",
        "role": "auxiliary",
        "shell": "top-nav-main",
        "features": [
          "creator-profile",
          "tier-display",
          "content-preview",
          "subscribe-flow"
        ],
        "description": "Public creator storefront for fans. Browse content, view tiers, and subscribe to creators.",
        "pages": [
          {
            "id": "profile",
            "layout": [
              "creator-profile",
              "tier-comparison"
            ],
            "route": "/creator/:username"
          },
          {
            "id": "post",
            "layout": [
              "post-list",
              "paywall"
            ],
            "route": "/creator/:username/post/:id"
          }
        ]
      },
      {
        "id": "fan-library",
        "role": "auxiliary",
        "shell": "top-nav-main",
        "features": [
          "content-library",
          "subscription-management",
          "download-content",
          "creator-links"
        ],
        "description": "Fan's purchased and subscribed content library. View all unlocked content and manage subscriptions.",
        "pages": [
          {
            "id": "library",
            "layout": [
              "filters",
              "content-card-grid"
            ],
            "route": "/library"
          },
          {
            "id": "subscriptions",
            "layout": [
              "card-grid"
            ],
            "route": "/library/subscriptions"
          }
        ]
      },
      {
        "id": "fan-checkout",
        "role": "auxiliary",
        "shell": "minimal-header",
        "features": [
          "stripe-integration",
          "promo-codes",
          "apple-pay",
          "google-pay"
        ],
        "description": "Purchase and subscription checkout flow for fans. Complete payment for subscriptions and one-time purchases.",
        "pages": [
          {
            "id": "checkout",
            "layout": [
              "checkout-flow"
            ],
            "route": "/checkout"
          },
          {
            "id": "purchase",
            "layout": [
              "checkout-flow"
            ],
            "route": "/checkout/purchase"
          },
          {
            "id": "success",
            "layout": [
              "chat-message"
            ],
            "route": "/checkout/success"
          }
        ]
      },
      {
        "id": "marketing-creator",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "hero-section",
          "feature-grid",
          "pricing-tiers",
          "testimonials",
          "faq"
        ],
        "description": "Platform marketing landing page for creator monetization. Attract creators with features, pricing, and testimonials.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "hero",
              "features",
              "how-it-works",
              "pricing",
              "testimonials",
              "cta"
            ],
            "route": "/"
          },
          {
            "id": "pricing",
            "layout": [
              "pricing",
              "faq"
            ],
            "route": "/pricing"
          }
        ]
      },
      {
        "id": "auth-full",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth",
          "mfa",
          "oauth",
          "email-verification",
          "password-reset"
        ],
        "description": "Complete authentication flow with login, register, forgot password, reset password, email verification, and MFA setup/verify.",
        "pages": [
          {
            "id": "login",
            "layout": [
              "form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              "form"
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              "form"
            ],
            "route": "/forgot-password"
          },
          {
            "id": "reset-password",
            "layout": [
              "form"
            ],
            "route": "/reset-password"
          },
          {
            "id": "verify-email",
            "layout": [
              "form"
            ],
            "route": "/verify-email"
          },
          {
            "id": "mfa-setup",
            "layout": [
              "form"
            ],
            "route": "/mfa-setup"
          },
          {
            "id": "mfa-verify",
            "layout": [
              "form"
            ],
            "route": "/mfa-verify"
          },
          {
            "id": "phone-verify",
            "layout": [
              "form"
            ]
          }
        ]
      },
      {
        "id": "settings-full",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "profile-edit",
          "password-change",
          "mfa-management",
          "session-management",
          "theme-toggle",
          "account-deletion"
        ],
        "description": "Complete account settings with profile, security (password, MFA, sessions), preferences (theme, notifications, language), and danger zone.",
        "pages": [
          {
            "id": "profile",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/profile"
          },
          {
            "id": "security",
            "layout": [
              "account-settings",
              "sessions"
            ],
            "route": "/settings/security"
          },
          {
            "id": "preferences",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/preferences"
          },
          {
            "id": "danger",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/account"
          }
        ]
      },
      {
        "id": "about-hybrid",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "team-grid",
          "values-display"
        ],
        "description": "About page combining hero, company story, team grid, values, and call-to-action sections.",
        "pages": [
          {
            "id": "about",
            "layout": [
              "hero",
              "story",
              "team",
              "values",
              "cta"
            ],
            "route": "/about"
          }
        ]
      },
      {
        "id": "contact",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "form-validation",
          "spam-protection",
          "file-attachment"
        ],
        "description": "Contact page with hero header and working contact form with validation and spam protection.",
        "pages": [
          {
            "id": "contact",
            "layout": [
              "hero",
              "form"
            ],
            "route": "/contact"
          }
        ]
      },
      {
        "id": "legal",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "toc-navigation",
          "print-friendly",
          "smooth-scroll"
        ],
        "description": "Legal pages including privacy policy, terms of service, and cookie policy with sticky TOC and print-friendly layout.",
        "pages": [
          {
            "id": "privacy",
            "layout": [
              "legal-prose"
            ],
            "route": "/privacy"
          },
          {
            "id": "terms",
            "layout": [
              "legal-prose"
            ],
            "route": "/terms"
          },
          {
            "id": "cookies",
            "layout": [
              "legal-prose"
            ]
          }
        ]
      }
    ],
    "features": [
      "earnings-kpis",
      "activity-feed",
      "quick-actions",
      "revenue-charts",
      "tier-breakdown",
      "payout-configuration",
      "export-reports",
      "media-upload",
      "tier-gating",
      "scheduling",
      "drafts",
      "subscriber-filtering",
      "export-csv",
      "messaging",
      "tier-management",
      "tier-creation",
      "benefit-management",
      "pricing-config",
      "tier-reorder",
      "creator-profile",
      "tier-display",
      "content-preview",
      "subscribe-flow",
      "content-library",
      "subscription-management",
      "download-content",
      "creator-links",
      "stripe-integration",
      "promo-codes",
      "apple-pay",
      "google-pay",
      "hero-section",
      "feature-grid",
      "pricing-tiers",
      "testimonials",
      "faq",
      "auth",
      "mfa",
      "oauth",
      "email-verification",
      "password-reset",
      "profile-edit",
      "password-change",
      "mfa-management",
      "session-management",
      "theme-toggle",
      "account-deletion",
      "team-grid",
      "values-display",
      "form-validation",
      "spam-protection",
      "file-attachment",
      "toc-navigation",
      "print-friendly",
      "smooth-scroll"
    ],
    "routes": {
      "/": {
        "section": "marketing-creator",
        "page": "home"
      },
      "/about": {
        "section": "about-hybrid",
        "page": "about"
      },
      "/login": {
        "section": "auth-full",
        "page": "login"
      },
      "/terms": {
        "section": "legal",
        "page": "terms"
      },
      "/contact": {
        "section": "contact",
        "page": "contact"
      },
      "/library": {
        "section": "fan-library",
        "page": "library"
      },
      "/pricing": {
        "section": "marketing-creator",
        "page": "pricing"
      },
      "/privacy": {
        "section": "legal",
        "page": "privacy"
      },
      "/checkout": {
        "section": "fan-checkout",
        "page": "checkout"
      },
      "/register": {
        "section": "auth-full",
        "page": "register"
      },
      "/dashboard": {
        "section": "creator-dashboard",
        "page": "home"
      },
      "/mfa-setup": {
        "section": "auth-full",
        "page": "mfa-setup"
      },
      "/mfa-verify": {
        "section": "auth-full",
        "page": "mfa-verify"
      },
      "/verify-email": {
        "section": "auth-full",
        "page": "verify-email"
      },
      "/reset-password": {
        "section": "auth-full",
        "page": "reset-password"
      },
      "/dashboard/tiers": {
        "section": "creator-tiers",
        "page": "tiers"
      },
      "/forgot-password": {
        "section": "auth-full",
        "page": "forgot-password"
      },
      "/checkout/success": {
        "section": "fan-checkout",
        "page": "success"
      },
      "/settings/account": {
        "section": "settings-full",
        "page": "danger"
      },
      "/settings/payouts": {
        "section": "creator-earnings",
        "page": "payouts"
      },
      "/settings/profile": {
        "section": "settings-full",
        "page": "profile"
      },
      "/checkout/purchase": {
        "section": "fan-checkout",
        "page": "purchase"
      },
      "/creator/:username": {
        "section": "fan-storefront",
        "page": "profile"
      },
      "/dashboard/content": {
        "section": "creator-content",
        "page": "content"
      },
      "/settings/security": {
        "section": "settings-full",
        "page": "security"
      },
      "/dashboard/earnings": {
        "section": "creator-earnings",
        "page": "earnings"
      },
      "/settings/preferences": {
        "section": "settings-full",
        "page": "preferences"
      },
      "/dashboard/content/new": {
        "section": "creator-content",
        "page": "new"
      },
      "/dashboard/subscribers": {
        "section": "creator-subscribers",
        "page": "subscribers"
      },
      "/library/subscriptions": {
        "section": "fan-library",
        "page": "subscriptions"
      },
      "/dashboard/subscribers/:id": {
        "section": "creator-subscribers",
        "page": "subscriber-detail"
      },
      "/creator/:username/post/:id": {
        "section": "fan-storefront",
        "page": "post"
      },
      "/dashboard/content/:id/edit": {
        "section": "creator-content",
        "page": "edit"
      }
    }
  },
  "meta": {
    "archetype": "creator-dashboard",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "WebApplication",
        "Product"
      ],
      "meta_priorities": [
        "description",
        "og:image",
        "twitter:card"
      ]
    },
    "navigation": {
      "hotkeys": [
        {
          "key": "g h",
          "label": "Go to Home",
          "route": "/"
        },
        {
          "key": "g d",
          "label": "Go to Dashboard",
          "route": "/dashboard"
        },
        {
          "key": "g e",
          "label": "Go to Earnings",
          "route": "/dashboard/earnings"
        },
        {
          "key": "g t",
          "label": "Go to Tiers",
          "route": "/dashboard/tiers"
        }
      ],
      "command_palette": true
    }
  }
}
