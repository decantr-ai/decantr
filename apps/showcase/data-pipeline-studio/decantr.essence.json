{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "terminal",
      "mode": "dark",
      "shape": "sharp"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "rounded",
      "base": 8
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "subtle",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Technical data engineering workspace with terminal-inspired aesthetics. Phosphor green/amber on black for pipeline canvas and log viewers. ASCII box borders on panels. Monospace everywhere. Visual pipeline builder uses nodes and edges with animated data flow particles. Source connectors show recognizable database/API icons. Transformation nodes show SQL/code previews. Think dbt Cloud meets Prefect meets a retro terminal. Lucide icons mixed with data-type icons."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "pipeline-builder",
        "role": "primary",
        "shell": "terminal-split",
        "features": [
          "pipelines",
          "visual-builder",
          "scheduling"
        ],
        "description": "Visual data pipeline builder with drag-and-drop canvas, pipeline list, and configuration for scheduling and retry policies.",
        "pages": [
          {
            "id": "pipelines",
            "layout": [
              "data-table"
            ],
            "route": "/pipelines"
          },
          {
            "id": "pipeline-editor",
            "layout": [
              "workflow-canvas"
            ],
            "route": "/pipelines/:id"
          },
          {
            "id": "pipeline-config",
            "layout": [
              "form-sections"
            ],
            "route": "/pipelines/:id/config"
          }
        ]
      },
      {
        "id": "source-catalog",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "sources",
          "connectors",
          "schemas"
        ],
        "description": "Data source management with browsable connector catalog, setup wizards, and active connection monitoring.",
        "pages": [
          {
            "id": "sources",
            "layout": [
              "data-source-connector"
            ],
            "route": "/sources"
          },
          {
            "id": "source-detail",
            "layout": [
              "data-source-connector",
              "json-viewer"
            ],
            "route": "/sources/:id"
          },
          {
            "id": "connections",
            "layout": [
              "data-source-connector"
            ],
            "route": "/connections"
          }
        ]
      },
      {
        "id": "transformation-editor",
        "role": "auxiliary",
        "shell": "sidebar-aside",
        "features": [
          "sql-editor",
          "transformations",
          "data-preview"
        ],
        "description": "SQL and code transformation editor with split-pane layout for writing queries alongside live data preview.",
        "pages": [
          {
            "id": "transforms",
            "layout": [
              "data-table"
            ],
            "route": "/transforms"
          },
          {
            "id": "transform-editor",
            "layout": [
              "split-pane"
            ],
            "route": "/transforms/:id"
          },
          {
            "id": "data-preview",
            "layout": [
              "data-table",
              "json-viewer"
            ],
            "route": "/transforms/preview"
          }
        ]
      },
      {
        "id": "job-monitor",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "monitoring",
          "logs",
          "job-history"
        ],
        "description": "Pipeline job run monitoring with run history, step-by-step trace waterfall, live log streaming, and performance KPIs.",
        "pages": [
          {
            "id": "jobs",
            "layout": [
              "data-table"
            ],
            "route": "/jobs"
          },
          {
            "id": "job-detail",
            "layout": [
              "kpi-grid",
              "trace-waterfall",
              "log-stream"
            ],
            "route": "/jobs/:id"
          }
        ]
      },
      {
        "id": "marketing-pipeline",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "marketing",
          "seo"
        ],
        "description": "Public marketing landing page for a data pipeline studio. Vision hero, feature highlights, how-it-works walkthrough, pricing tiers, and call-to-action.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "hero",
              "features",
              "how-it-works",
              "pricing",
              "cta-section"
            ],
            "route": "/"
          }
        ]
      },
      {
        "id": "auth-full",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth",
          "mfa",
          "oauth",
          "email-verification",
          "password-reset"
        ],
        "description": "Complete authentication flow with login, register, forgot password, reset password, email verification, and MFA setup/verify.",
        "pages": [
          {
            "id": "login",
            "layout": [
              "form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              "form"
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              "form"
            ],
            "route": "/forgot-password"
          },
          {
            "id": "reset-password",
            "layout": [
              "form"
            ],
            "route": "/reset-password"
          },
          {
            "id": "verify-email",
            "layout": [
              "form"
            ],
            "route": "/verify-email"
          },
          {
            "id": "mfa-setup",
            "layout": [
              "form"
            ],
            "route": "/mfa-setup"
          },
          {
            "id": "mfa-verify",
            "layout": [
              "form"
            ],
            "route": "/mfa-verify"
          },
          {
            "id": "phone-verify",
            "layout": [
              "form"
            ],
            "route": "/phone-verify"
          }
        ]
      },
      {
        "id": "settings-full",
        "role": "auxiliary",
        "shell": "terminal-split",
        "features": [
          "profile-edit",
          "password-change",
          "mfa-management",
          "session-management",
          "theme-toggle",
          "account-deletion"
        ],
        "description": "Complete account settings with profile, security (password, MFA, sessions), preferences (theme, notifications, language), and danger zone.",
        "pages": [
          {
            "id": "profile",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/profile"
          },
          {
            "id": "security",
            "layout": [
              "account-settings",
              "sessions"
            ],
            "route": "/settings/security"
          },
          {
            "id": "preferences",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/preferences"
          },
          {
            "id": "danger",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/danger"
          }
        ]
      }
    ],
    "features": [
      "pipelines",
      "visual-builder",
      "scheduling",
      "sources",
      "connectors",
      "schemas",
      "sql-editor",
      "transformations",
      "data-preview",
      "monitoring",
      "logs",
      "job-history",
      "marketing",
      "seo",
      "auth",
      "mfa",
      "oauth",
      "email-verification",
      "password-reset",
      "profile-edit",
      "password-change",
      "mfa-management",
      "session-management",
      "theme-toggle",
      "account-deletion",
      "command-palette"
    ],
    "routes": {
      "/": {
        "section": "marketing-pipeline",
        "page": "home"
      },
      "/jobs": {
        "section": "job-monitor",
        "page": "jobs"
      },
      "/login": {
        "section": "auth-full",
        "page": "login"
      },
      "/sources": {
        "section": "source-catalog",
        "page": "sources"
      },
      "/jobs/:id": {
        "section": "job-monitor",
        "page": "job-detail"
      },
      "/register": {
        "section": "auth-full",
        "page": "register"
      },
      "/mfa-setup": {
        "section": "auth-full",
        "page": "mfa-setup"
      },
      "/pipelines": {
        "section": "pipeline-builder",
        "page": "pipelines"
      },
      "/mfa-verify": {
        "section": "auth-full",
        "page": "mfa-verify"
      },
      "/transforms": {
        "section": "transformation-editor",
        "page": "transforms"
      },
      "/connections": {
        "section": "source-catalog",
        "page": "connections"
      },
      "/sources/:id": {
        "section": "source-catalog",
        "page": "source-detail"
      },
      "/phone-verify": {
        "section": "auth-full",
        "page": "phone-verify"
      },
      "/verify-email": {
        "section": "auth-full",
        "page": "verify-email"
      },
      "/pipelines/:id": {
        "section": "pipeline-builder",
        "page": "pipeline-editor"
      },
      "/reset-password": {
        "section": "auth-full",
        "page": "reset-password"
      },
      "/transforms/:id": {
        "section": "transformation-editor",
        "page": "transform-editor"
      },
      "/forgot-password": {
        "section": "auth-full",
        "page": "forgot-password"
      },
      "/settings/danger": {
        "section": "settings-full",
        "page": "danger"
      },
      "/settings/profile": {
        "section": "settings-full",
        "page": "profile"
      },
      "/settings/security": {
        "section": "settings-full",
        "page": "security"
      },
      "/transforms/preview": {
        "section": "transformation-editor",
        "page": "data-preview"
      },
      "/pipelines/:id/config": {
        "section": "pipeline-builder",
        "page": "pipeline-config"
      },
      "/settings/preferences": {
        "section": "settings-full",
        "page": "preferences"
      }
    }
  },
  "meta": {
    "archetype": "pipeline-builder",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "WebApplication",
        "SoftwareApplication"
      ],
      "meta_priorities": [
        "description",
        "og:image",
        "twitter:card"
      ]
    },
    "navigation": {
      "hotkeys": [
        {
          "key": "g p",
          "label": "Go to Pipelines",
          "route": "/pipelines"
        },
        {
          "key": "g s",
          "label": "Go to Sources",
          "route": "/sources"
        },
        {
          "key": "g t",
          "label": "Go to Transforms",
          "route": "/transforms"
        },
        {
          "key": "g j",
          "label": "Go to Jobs",
          "route": "/jobs"
        }
      ],
      "command_palette": true
    }
  }
}
