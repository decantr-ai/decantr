{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "cinema",
      "mode": "dark",
      "shape": "rounded"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 700,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "sharp",
      "base": 8
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "expressive",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Professional AI video production studio. Dark charcoal timelines with warm amber accents on active elements. Film-grain textures and title-card typography. Multi-track timeline dominates the workspace with scrubber, scene thumbnails, and keyframe dots. Character consistency sheets hang in sidebar panels. Render queue shows live generation progress. Think Runway meets Final Cut Pro. Lucide icons. Cinematic."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "project-library",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "project-management",
          "templates"
        ],
        "description": "Browse, filter, and manage video projects and starter templates. Entry point for opening existing work and kicking off new productions from curated blueprints.",
        "pages": [
          {
            "id": "projects",
            "layout": [
              "project-cards",
              "project-table"
            ],
            "route": "/projects"
          },
          {
            "id": "templates",
            "layout": [
              "filters",
              "template-gallery"
            ],
            "route": "/projects/templates"
          }
        ]
      },
      {
        "id": "character-library",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "character-tracking",
          "consistency"
        ],
        "description": "Manage reusable AI character references with persistent identity, appearance details, and consistency tracking across video scenes.",
        "pages": [
          {
            "id": "characters",
            "layout": [
              "filters",
              "character-cards"
            ],
            "route": "/characters"
          },
          {
            "id": "character-detail",
            "layout": [
              "full-sheet",
              "appearances"
            ],
            "route": "/characters/:id"
          }
        ]
      },
      {
        "id": "prompt-director",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "prompt-management",
          "version-control"
        ],
        "description": "Organize, version, and iterate on scene prompts. Provides a prompt library, full-fidelity editor with live playground, and inline storyboard strip for visual reference.",
        "pages": [
          {
            "id": "prompts",
            "layout": [
              "filters",
              "prompt-table"
            ],
            "route": "/prompts"
          },
          {
            "id": "prompt-detail",
            "layout": [
              "editor",
              "reference-strip"
            ],
            "route": "/prompts/:id"
          }
        ]
      },
      {
        "id": "render-monitor",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "render-monitoring",
          "logs"
        ],
        "description": "Observe every render job in flight: queue, progress, GPU utilization, and live log streaming for diagnosing failed or slow video generations.",
        "pages": [
          {
            "id": "renders",
            "layout": [
              "filters",
              "queue-list"
            ],
            "route": "/renders"
          },
          {
            "id": "render-detail",
            "layout": [
              "job-header",
              "live-logs"
            ],
            "route": "/renders/:id"
          }
        ]
      },
      {
        "id": "marketing-video-studio",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "marketing",
          "seo"
        ],
        "description": "Public-facing landing page for an AI video studio product. Communicates vision, showcases features and workflow, presents pricing tiers, and drives signups with social proof.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "hero",
              "features",
              "workflow",
              "pricing",
              "social-proof",
              "final-cta"
            ],
            "route": "/"
          }
        ]
      },
      {
        "id": "auth-full",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth",
          "mfa",
          "oauth",
          "email-verification",
          "password-reset"
        ],
        "description": "Complete authentication flow with login, register, forgot password, reset password, email verification, and MFA setup/verify.",
        "pages": [
          {
            "id": "login",
            "layout": [
              "form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              "form"
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              "form"
            ],
            "route": "/forgot-password"
          },
          {
            "id": "reset-password",
            "layout": [
              "form"
            ],
            "route": "/reset-password"
          },
          {
            "id": "verify-email",
            "layout": [
              "form"
            ],
            "route": "/verify-email"
          },
          {
            "id": "mfa-setup",
            "layout": [
              "form"
            ],
            "route": "/mfa-setup"
          },
          {
            "id": "mfa-verify",
            "layout": [
              "form"
            ],
            "route": "/mfa-verify"
          },
          {
            "id": "phone-verify",
            "layout": [
              "form"
            ],
            "route": "/phone-verify"
          }
        ]
      },
      {
        "id": "settings-full",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "profile-edit",
          "password-change",
          "mfa-management",
          "session-management",
          "theme-toggle",
          "account-deletion"
        ],
        "description": "Complete account settings with profile, security (password, MFA, sessions), preferences (theme, notifications, language), and danger zone.",
        "pages": [
          {
            "id": "profile",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/profile"
          },
          {
            "id": "security",
            "layout": [
              "account-settings",
              "sessions"
            ],
            "route": "/settings/security"
          },
          {
            "id": "preferences",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/preferences"
          },
          {
            "id": "danger",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/danger"
          }
        ]
      }
    ],
    "features": [
      "project-management",
      "templates",
      "character-tracking",
      "consistency",
      "prompt-management",
      "version-control",
      "render-monitoring",
      "logs",
      "marketing",
      "seo",
      "auth",
      "mfa",
      "oauth",
      "email-verification",
      "password-reset",
      "profile-edit",
      "password-change",
      "mfa-management",
      "session-management",
      "theme-toggle",
      "account-deletion"
    ],
    "routes": {
      "/": {
        "section": "marketing-video-studio",
        "page": "home"
      },
      "/login": {
        "section": "auth-full",
        "page": "login"
      },
      "/editor": {
        "section": "video-editor",
        "page": "editor"
      },
      "/prompts": {
        "section": "prompt-director",
        "page": "prompts"
      },
      "/renders": {
        "section": "render-monitor",
        "page": "renders"
      },
      "/projects": {
        "section": "project-library",
        "page": "projects"
      },
      "/register": {
        "section": "auth-full",
        "page": "register"
      },
      "/mfa-setup": {
        "section": "auth-full",
        "page": "mfa-setup"
      },
      "/characters": {
        "section": "character-library",
        "page": "characters"
      },
      "/editor/:id": {
        "section": "video-editor",
        "page": "project-detail"
      },
      "/mfa-verify": {
        "section": "auth-full",
        "page": "mfa-verify"
      },
      "/prompts/:id": {
        "section": "prompt-director",
        "page": "prompt-detail"
      },
      "/renders/:id": {
        "section": "render-monitor",
        "page": "render-detail"
      },
      "/phone-verify": {
        "section": "auth-full",
        "page": "phone-verify"
      },
      "/verify-email": {
        "section": "auth-full",
        "page": "verify-email"
      },
      "/editor/export": {
        "section": "video-editor",
        "page": "export"
      },
      "/characters/:id": {
        "section": "character-library",
        "page": "character-detail"
      },
      "/reset-password": {
        "section": "auth-full",
        "page": "reset-password"
      },
      "/forgot-password": {
        "section": "auth-full",
        "page": "forgot-password"
      },
      "/settings/danger": {
        "section": "settings-full",
        "page": "danger"
      },
      "/settings/profile": {
        "section": "settings-full",
        "page": "profile"
      },
      "/settings/security": {
        "section": "settings-full",
        "page": "security"
      },
      "/projects/templates": {
        "section": "project-library",
        "page": "templates"
      },
      "/settings/preferences": {
        "section": "settings-full",
        "page": "preferences"
      }
    }
  },
  "meta": {
    "archetype": "video-editor",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "WebApplication"
      ],
      "meta_priorities": [
        "description",
        "og:image",
        "twitter:card"
      ]
    },
    "navigation": {
      "hotkeys": [],
      "command_palette": true
    }
  }
}
