{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "luminarum",
      "mode": "dark",
      "shape": "rounded"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "rounded",
      "base": 8
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "subtle",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Bold, high-impact product landing page designed to convert. Dark premium background with vibrant geometric accent elements. Split hero with confident typography and a prominent CTA button. Feature sections alternate between full-bleed and contained layouts for visual rhythm. Social proof is prominent — logos, testimonials, case study snippets. The pricing section is clear and decisive. Below-the-fold content builds the narrative: problem → solution → proof → action. Blog/resources add SEO depth. Lucide icons. Mobile-first, fast-loading."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "landing-hero",
        "role": "primary",
        "shell": "full-bleed",
        "features": [
          "marketing",
          "seo",
          "analytics"
        ],
        "description": "High-impact product landing page with split hero, feature sections, how-it-works flow, pricing, testimonials, and conversion-optimized CTAs. Full-bleed scroll experience designed to convert visitors.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "split-hero",
              "feature-showcase",
              "workflow-steps",
              "pricing-tiers",
              "social-proof",
              "bottom-cta"
            ],
            "route": "/"
          },
          {
            "id": "demo",
            "layout": [
              "demo-hero",
              "demo-features"
            ],
            "route": "/demo"
          }
        ]
      },
      {
        "id": "landing-resources",
        "role": "auxiliary",
        "shell": "top-nav-main",
        "features": [
          "seo",
          "search",
          "rss"
        ],
        "description": "Resources and blog section for a product landing site. Provides SEO depth with blog posts, guides, and resource listings that support the main product narrative.",
        "pages": [
          {
            "id": "blog",
            "layout": [
              "blog-cards"
            ],
            "route": "/blog"
          },
          {
            "id": "blog-post",
            "layout": [
              "breadcrumbs",
              "post-body"
            ],
            "route": "/blog/:id"
          },
          {
            "id": "resources",
            "layout": [
              "resource-cards"
            ],
            "route": "/resources"
          }
        ]
      },
      {
        "id": "landing-legal",
        "role": "auxiliary",
        "shell": "top-nav-footer",
        "features": [
          "seo"
        ],
        "description": "Legal pages for a product landing site including privacy policy and terms of service. Clean prose layouts for legal content.",
        "pages": [
          {
            "id": "privacy",
            "layout": [
              "privacy-content"
            ],
            "route": "/privacy"
          },
          {
            "id": "terms",
            "layout": [
              "terms-content"
            ],
            "route": "/terms"
          }
        ]
      }
    ],
    "features": [
      "marketing",
      "seo",
      "analytics",
      "search",
      "rss"
    ],
    "routes": {
      "/": {
        "section": "landing-hero",
        "page": "home"
      },
      "/blog": {
        "section": "landing-resources",
        "page": "blog"
      },
      "/demo": {
        "section": "landing-hero",
        "page": "demo"
      },
      "/terms": {
        "section": "landing-legal",
        "page": "terms"
      },
      "/privacy": {
        "section": "landing-legal",
        "page": "privacy"
      },
      "/blog/:id": {
        "section": "landing-resources",
        "page": "blog-post"
      },
      "/resources": {
        "section": "landing-resources",
        "page": "resources"
      }
    }
  },
  "meta": {
    "archetype": "landing-hero",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "WebSite",
        "SoftwareApplication",
        "Product"
      ],
      "meta_priorities": [
        "description",
        "og:title",
        "og:image"
      ]
    },
    "navigation": {
      "hotkeys": [
        {
          "key": "g h",
          "label": "Go to Home",
          "route": "/"
        },
        {
          "key": "g b",
          "label": "Go to Blog",
          "route": "/blog"
        },
        {
          "key": "g r",
          "label": "Go to Resources",
          "route": "/resources"
        }
      ],
      "command_palette": false
    }
  }
}
