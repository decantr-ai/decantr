{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "estate",
      "mode": "light",
      "shape": "rounded"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "rounded",
      "base": 8
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "subtle",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Professional, trust-building property management portal with a warm light theme. Clean card-based layouts for properties and units with status badges (occupied, vacant, maintenance). Financial views use conservative chart styles — bar charts for rent roll, line charts for P&L trends. Tenant directory emphasizes contact info and lease status. Maintenance board uses a kanban layout with priority coloring. The tenant portal feels welcoming and self-service. Think Buildium meets a modern banking app — serious about money, friendly about people."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "owner-dashboard",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "dashboard",
          "analytics",
          "notifications"
        ],
        "description": "Property owner/investor portfolio dashboard with financial overview, property grid, rent collection status, maintenance summary, and vacancy tracking.",
        "pages": [
          {
            "id": "dashboard",
            "layout": [
              "alerts",
              "financials",
              "rent-roll",
              "vacancies",
              "maintenance-board",
              "properties"
            ],
            "route": "/dashboard"
          }
        ]
      },
      {
        "id": "property-manager",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "crud",
          "file-upload",
          "search",
          "filters"
        ],
        "description": "Property CRUD and management screens including property list, detail view, create/edit forms, and unit management.",
        "pages": [
          {
            "id": "list",
            "layout": [
              "property-grid"
            ],
            "route": "/properties"
          },
          {
            "id": "detail",
            "layout": [
              "property-detail"
            ],
            "route": "/properties/:id"
          },
          {
            "id": "create",
            "layout": [
              "form"
            ],
            "route": "/properties/new"
          },
          {
            "id": "units",
            "layout": [
              "units"
            ],
            "route": "/properties/:id/units"
          },
          {
            "id": "unit-detail",
            "layout": [
              "unit-detail"
            ],
            "route": "/properties/:id/units/:unitId"
          }
        ]
      },
      {
        "id": "tenant-manager",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "crud",
          "search",
          "filters",
          "communication"
        ],
        "description": "Tenant management screens including directory, detail view with lease and payment history, and tenant onboarding.",
        "pages": [
          {
            "id": "list",
            "layout": [
              "tenant-directory"
            ],
            "route": "/tenants"
          },
          {
            "id": "detail",
            "layout": [
              "creator-profile",
              "lease-manager",
              "payments"
            ],
            "route": "/tenants/:id"
          },
          {
            "id": "create",
            "layout": [
              "form",
              "form"
            ]
          }
        ]
      },
      {
        "id": "pm-financials",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "analytics",
          "export",
          "charts",
          "date-range"
        ],
        "description": "Property management financial analytics including P&L overview, rent roll, expense tracking, and payment history for real estate portfolios.",
        "pages": [
          {
            "id": "overview",
            "layout": [
              "pnl-dashboard"
            ],
            "route": "/financials"
          },
          {
            "id": "rent-roll",
            "layout": [
              "rent-roll"
            ],
            "route": "/financials/rent-roll"
          },
          {
            "id": "expenses",
            "layout": [
              "expenses"
            ],
            "route": "/financials/expenses"
          },
          {
            "id": "payments",
            "layout": [
              "payments"
            ]
          }
        ]
      },
      {
        "id": "maintenance-center",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "kanban",
          "drag-drop",
          "file-upload",
          "notifications"
        ],
        "description": "Maintenance ticket management with Kanban board view, ticket details, and ticket creation for property repairs.",
        "pages": [
          {
            "id": "board",
            "layout": [
              "board",
              "maintenance-board"
            ],
            "route": "/maintenance"
          },
          {
            "id": "ticket",
            "layout": [
              "maintenance-ticket"
            ],
            "route": "/maintenance/:id"
          },
          {
            "id": "create",
            "layout": [
              "form"
            ]
          }
        ]
      },
      {
        "id": "tenant-portal",
        "role": "auxiliary",
        "shell": "top-nav-main",
        "features": [
          "self-service",
          "file-upload",
          "notifications"
        ],
        "description": "Tenant self-service portal home with lease summary, rent reminders, recent maintenance tickets, and quick actions.",
        "pages": [
