  "meta": {
    "archetype": "owner-dashboard",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "WebApplication",
        "RealEstateAgent"
      ],
      "meta_priorities": [
        "description",
        "og:image",
        "twitter:card"
