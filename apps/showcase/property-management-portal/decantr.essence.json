            "id": "maintenance",
            "layout": [
              "form"
            ],
            "route": "/tenant-portal/maintenance"
          },
          {
            "id": "documents",
            "layout": [
              "documents"
            ],
            "route": "/tenant-portal/documents"
          }
        ]
      },
      {
        "id": "tenant-payments",
        "role": "auxiliary",
        "shell": "top-nav-main",
        "features": [
          "payments",
          "autopay",
          "receipts"
        ],
        "description": "Tenant payment management including rent reminders, payment history, and autopay setup configuration.",
        "pages": [
