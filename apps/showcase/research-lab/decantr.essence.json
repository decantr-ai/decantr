{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "lab",
      "mode": "light",
      "shape": "sharp"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 500,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "sharp",
      "base": 2
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "minimal",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Scientific research workspace with pristine white panels and technical cyan accents. Lab notebook entries with LaTeX formula blocks and image embeds. Protocol steps numbered with reagent lists, equipment chips, and safety badges. Sample trackers with barcode displays and expiry countdowns. Instrument scheduling grids show bookings across lab equipment. Dataset cards with schema trees and quality indicators. Think Benchling meets Jupyter. Lucide icons. Precise."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "lab-notebook",
        "role": "primary",
        "shell": "sidebar-aside",
        "features": [
          "notebook",
          "entries",
          "authoring",
          "protocols"
        ],
        "description": "Primary authoring surface for a scientific research lab. Researchers maintain an electronic lab notebook with hierarchical page tree, rich entries, and checklist protocols.",
        "pages": [
          {
            "id": "notebook",
            "layout": [
              "page-tree",
              "notebook-entry"
            ],
            "route": "/notebook"
          },
          {
            "id": "entry-detail",
            "layout": [
              "notebook-entry",
              "protocol-step"
            ],
            "route": "/notebook/:id"
          }
        ]
      },
      {
        "id": "experiment-tracker",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "experiments",
          "protocols",
          "tracking"
        ],
        "description": "Experiment lifecycle management for a research lab. Researchers track planned, in-progress, and completed experiments with protocols and timelines.",
        "pages": [
          {
            "id": "experiments",
            "layout": [
              "kanban-board",
              "data-table"
            ],
            "route": "/experiments"
          },
          {
            "id": "experiment-detail",
            "layout": [
              "detail-header",
              "protocol-step",
              "timeline"
            ],
            "route": "/experiments/:id"
          }
        ]
      },
      {
        "id": "sample-inventory",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "samples",
          "chain-of-custody",
          "inventory"
        ],
        "description": "Biological and chemical sample inventory management with chain-of-custody tracking. Researchers locate, log, and audit every sample in the lab.",
        "pages": [
          {
            "id": "samples",
            "layout": [
              "search-filter-bar",
              "sample-tracker"
            ],
            "route": "/samples"
          },
          {
            "id": "sample-detail",
            "layout": [
              "detail-header",
              "sample-tracker"
            ],
            "route": "/samples/:id"
          }
        ]
      },
      {
        "id": "instrument-booking",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "booking",
          "scheduling",
          "instruments"
        ],
        "description": "Shared instrument reservation system for research labs. Researchers see availability calendars for lab equipment and book time slots.",
        "pages": [
          {
            "id": "instruments",
            "layout": [
              "card-grid",
              "instrument-schedule"
            ],
            "route": "/instruments"
          },
          {
            "id": "instrument-detail",
            "layout": [
              "detail-header",
              "instrument-schedule",
              "data-table"
            ],
            "route": "/instruments/:id"
          }
        ]
      },
      {
        "id": "data-repository",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "datasets",
          "repository",
          "data-catalog"
        ],
        "description": "Research dataset library for a scientific lab. Scientists publish, browse, and inspect structured datasets produced by experiments.",
        "pages": [
          {
            "id": "datasets",
            "layout": [
              "search-filter-bar",
              "card-grid"
            ],
            "route": "/datasets"
          },
          {
            "id": "dataset-detail",
            "layout": [
              "dataset-card",
              "data-table"
            ],
            "route": "/datasets/:id"
          }
        ]
      },
      {
        "id": "marketing-research",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "marketing",
          "landing",
          "about"
        ],
        "description": "Public marketing home page for a scientific research lab. Introduces the lab, its research focus, and drives visitors toward publications and collaboration.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "hero",
              "features",
              "testimonials",
              "cta-section"
            ],
            "route": "/"
          }
        ]
      },
      {
        "id": "auth-full",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth",
          "mfa",
          "oauth",
          "email-verification",
          "password-reset"
        ],
        "description": "Complete authentication flow with login, register, forgot password, reset password, email verification, and MFA setup/verify.",
        "pages": [
          {
            "id": "login",
            "layout": [
              "form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              "form"
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              "form"
            ],
            "route": "/forgot-password"
          },
          {
            "id": "reset-password",
            "layout": [
              "form"
            ],
            "route": "/reset-password"
          },
          {
            "id": "verify-email",
            "layout": [
              "form"
            ],
            "route": "/verify-email"
          },
          {
            "id": "mfa-setup",
            "layout": [
              "form"
            ],
            "route": "/mfa-setup"
          },
          {
            "id": "mfa-verify",
            "layout": [
              "form"
            ],
            "route": "/mfa-verify"
          },
          {
            "id": "phone-verify",
            "layout": [
              "form"
            ],
            "route": "/phone-verify"
          }
        ]
      },
      {
        "id": "settings-full",
        "role": "auxiliary",
        "shell": "sidebar-aside",
        "features": [
          "profile-edit",
          "password-change",
          "mfa-management",
          "session-management",
          "theme-toggle",
          "account-deletion"
        ],
        "description": "Complete account settings with profile, security (password, MFA, sessions), preferences (theme, notifications, language), and danger zone.",
        "pages": [
          {
            "id": "profile",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/profile"
          },
          {
            "id": "security",
            "layout": [
              "account-settings",
              "sessions"
            ],
            "route": "/settings/security"
          },
          {
            "id": "preferences",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/preferences"
          },
          {
            "id": "danger",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/danger"
          }
        ]
      }
    ],
    "features": [
      "notebook",
      "entries",
      "authoring",
      "protocols",
      "experiments",
      "tracking",
      "samples",
      "chain-of-custody",
      "inventory",
      "booking",
      "scheduling",
      "instruments",
      "datasets",
      "repository",
      "data-catalog",
      "marketing",
      "landing",
      "about",
      "auth",
      "mfa",
      "oauth",
      "email-verification",
      "password-reset",
      "profile-edit",
      "password-change",
      "mfa-management",
      "session-management",
      "theme-toggle",
      "account-deletion"
    ],
    "routes": {
      "/": {
        "section": "marketing-research",
        "page": "home"
      },
      "/login": {
        "section": "auth-full",
        "page": "login"
      },
      "/samples": {
        "section": "sample-inventory",
        "page": "samples"
      },
      "/datasets": {
        "section": "data-repository",
        "page": "datasets"
      },
      "/notebook": {
        "section": "lab-notebook",
        "page": "notebook"
      },
      "/register": {
        "section": "auth-full",
        "page": "register"
      },
      "/mfa-setup": {
        "section": "auth-full",
        "page": "mfa-setup"
      },
      "/mfa-verify": {
        "section": "auth-full",
        "page": "mfa-verify"
      },
      "/experiments": {
        "section": "experiment-tracker",
        "page": "experiments"
      },
      "/instruments": {
        "section": "instrument-booking",
        "page": "instruments"
      },
      "/samples/:id": {
        "section": "sample-inventory",
        "page": "sample-detail"
      },
      "/datasets/:id": {
        "section": "data-repository",
        "page": "dataset-detail"
      },
      "/notebook/:id": {
        "section": "lab-notebook",
        "page": "entry-detail"
      },
      "/phone-verify": {
        "section": "auth-full",
        "page": "phone-verify"
      },
      "/verify-email": {
        "section": "auth-full",
        "page": "verify-email"
      },
      "/reset-password": {
        "section": "auth-full",
        "page": "reset-password"
      },
      "/experiments/:id": {
        "section": "experiment-tracker",
        "page": "experiment-detail"
      },
      "/forgot-password": {
        "section": "auth-full",
        "page": "forgot-password"
      },
      "/instruments/:id": {
        "section": "instrument-booking",
        "page": "instrument-detail"
      },
      "/settings/danger": {
        "section": "settings-full",
        "page": "danger"
      },
      "/settings/profile": {
        "section": "settings-full",
        "page": "profile"
      },
      "/settings/security": {
        "section": "settings-full",
        "page": "security"
      },
      "/settings/preferences": {
        "section": "settings-full",
        "page": "preferences"
      }
    }
  },
  "meta": {
    "archetype": "lab-notebook",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "ResearchProject"
      ],
      "meta_priorities": [
        "description",
        "og:image"
      ]
    },
    "navigation": {
      "hotkeys": [],
      "command_palette": true
    }
  }
}
