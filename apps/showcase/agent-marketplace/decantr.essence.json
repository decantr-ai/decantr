{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "carbon-neon",
      "mode": "dark",
      "shape": "rounded"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "rounded",
      "base": 8
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "subtle",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Confident cyber-minimal agent marketplace. Neon accent glows on dark void backgrounds. Monospace data typography. Agent status shown through color-coded rings and pulse animations. Think Linear meets a mission control center. Lucide icons. No decorative elements — every pixel serves the operator."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "agent-orchestrator",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "agents",
          "monitoring",
          "orchestration",
          "real-time",
          "websockets"
        ],
        "description": "Multi-agent management dashboard for monitoring, configuring, and orchestrating autonomous agent swarms with real-time status and marketplace discovery.",
        "pages": [
          {
            "id": "agent-overview",
            "layout": [
              {
                "as": "swarm-topology",
                "pattern": "agent-swarm-canvas"
              },
              {
                "as": "activity-feed",
                "pattern": "agent-timeline"
              }
            ],
            "route": "/agents"
          },
          {
            "id": "agent-detail",
            "layout": [
              {
                "as": "agent-history",
                "pattern": "agent-timeline"
              },
              {
                "as": "feedback-inspector",
                "pattern": "neural-feedback-loop"
              }
            ],
            "route": "/agents/:id"
          },
          {
            "id": "agent-config",
            "layout": [
              "nav-header",
              {
                "as": "agent-parameters",
                "preset": "structured",
                "pattern": "form-sections"
              }
            ],
            "route": "/agents/config"
          },
          {
            "id": "agent-marketplace",
            "layout": [
              {
                "as": "marketplace-hero",
                "preset": "standard",
                "pattern": "hero"
              },
              {
                "as": "agent-catalog",
                "pattern": "generative-card-grid"
              }
            ],
            "route": "/marketplace"
          }
        ]
      },
      {
        "id": "auth-full",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth",
          "mfa",
          "oauth",
          "email-verification",
          "password-reset"
        ],
        "description": "Complete authentication flow with login, register, forgot password, reset password, email verification, and MFA setup/verify.",
        "pages": [
          {
            "id": "login",
            "layout": [
              "form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              "form"
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              "form"
            ],
            "route": "/forgot-password"
          },
          {
            "id": "reset-password",
            "layout": [
              "form"
            ],
            "route": "/reset-password"
          },
          {
            "id": "verify-email",
            "layout": [
              "form"
            ],
            "route": "/verify-email"
          },
          {
            "id": "mfa-setup",
            "layout": [
              "form"
            ]
          },
          {
            "id": "mfa-verify",
            "layout": [
              "form"
            ]
          },
          {
            "id": "phone-verify",
            "layout": [
              "form"
            ]
          }
        ]
      },
      {
        "id": "marketing-saas",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "pricing-toggle",
          "testimonials",
          "feature-grid"
        ],
        "description": "SaaS marketing landing page with hero, features, how-it-works timeline, pricing, testimonials, and CTA sections.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "hero",
              "features",
              "how-it-works",
              "pricing",
              "testimonials",
              "cta"
            ],
            "route": "/"
          }
        ]
      },
      {
        "id": "ai-transparency",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "monitoring",
          "analytics",
          "observability"
        ],
        "description": "AI model observability and transparency dashboard for inspecting inference logs, confidence distributions, and neural feedback cycles across deployed models.",
        "pages": [
          {
            "id": "model-overview",
            "layout": [
              {
                "as": "model-kpis",
                "pattern": "stats-overview"
              },
              {
                "as": "feedback-summary",
                "pattern": "neural-feedback-loop"
              }
            ],
            "route": "/transparency"
          },
          {
            "id": "inference-log",
            "layout": [
              {
                "as": "inference-trace",
                "pattern": "agent-timeline"
              }
            ],
            "route": "/transparency/inference"
          },
          {
            "id": "confidence-explorer",
            "layout": [
              {
                "as": "confidence-distribution",
                "pattern": "intent-radar"
              },
              {
                "as": "metric-breakdown",
                "pattern": "stats-overview"
              }
            ],
            "route": "/transparency/confidence"
          }
        ]
      }
    ],
    "features": [
      "agents",
      "monitoring",
      "orchestration",
      "real-time",
      "websockets",
      "auth",
      "mfa",
      "oauth",
      "email-verification",
      "password-reset",
      "pricing-toggle",
      "testimonials",
      "feature-grid",
      "analytics",
      "observability",
      "theme-toggle",
      "command-palette"
    ],
    "routes": {
      "/": {
        "section": "marketing-saas",
        "page": "home"
      },
      "/login": {
        "section": "auth-full",
        "page": "login"
      },
      "/agents": {
        "section": "agent-orchestrator",
        "page": "agent-overview"
      },
      "/register": {
        "section": "auth-full",
        "page": "register"
      },
      "/agents/:id": {
        "section": "agent-orchestrator",
        "page": "agent-detail"
      },
      "/marketplace": {
        "section": "agent-orchestrator",
        "page": "agent-marketplace"
      },
      "/transparency": {
        "section": "ai-transparency",
        "page": "model-overview"
      },
      "/verify-email": {
        "section": "auth-full",
        "page": "verify-email"
      },
      "/agents/config": {
        "section": "agent-orchestrator",
        "page": "agent-config"
      },
      "/reset-password": {
        "section": "auth-full",
        "page": "reset-password"
      },
      "/forgot-password": {
        "section": "auth-full",
        "page": "forgot-password"
      },
      "/transparency/inference": {
        "section": "ai-transparency",
        "page": "inference-log"
      },
      "/transparency/confidence": {
        "section": "ai-transparency",
        "page": "confidence-explorer"
      }
    }
  },
  "meta": {
    "archetype": "agent-orchestrator",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "WebApplication",
        "SoftwareApplication"
      ],
      "meta_priorities": [
        "description",
        "og:image",
        "twitter:card"
      ]
    },
    "navigation": {
      "hotkeys": [
        {
          "key": "g a",
          "label": "Go to Agents",
          "route": "/agents"
        },
        {
          "key": "g m",
          "label": "Go to Marketplace",
          "route": "/marketplace"
        },
        {
          "key": "g t",
          "label": "Go to Transparency",
          "route": "/transparency"
        }
      ],
      "command_palette": true
    }
  }
}
