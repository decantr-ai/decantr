{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "editorial",
      "mode": "light",
      "shape": "sharp"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "sharp",
      "base": 2
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "none",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Reading-first content site optimized for long-form consumption. Generous line-height, comfortable measure (65-75 characters), and a clear typographic hierarchy that makes scanning effortless. Article cards feature bold headlines with subtle metadata. The reading view strips away distractions — just text, well-set. Author dashboard is functional and focused. Newsletter archive is clean and browsable. Think Substack meets Medium's typography. Lucide icons. Dark mode available for night reading."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "content-reader",
        "role": "primary",
        "shell": "top-nav-main",
        "features": [
          "search",
          "reading",
          "rss",
          "bookmarks"
        ],
        "description": "Article reading experience with browsable article listings, full article detail view, and category navigation. Optimized for long-form consumption with generous typography and effortless scanning.",
        "pages": [
          {
            "id": "articles",
            "layout": [
              "article-search",
              "article-cards"
            ],
            "route": "/articles"
          },
          {
            "id": "article-detail",
            "layout": [
              "breadcrumbs",
              "article-body"
            ],
            "route": "/articles/:id"
          },
          {
            "id": "categories",
            "layout": [
              "category-grid"
            ],
            "route": "/categories"
          }
        ]
      },
      {
        "id": "content-author",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "editing",
          "publishing",
          "auto-save",
          "markdown"
        ],
        "description": "Author and editor dashboard for managing drafts, editing articles, and viewing published content. Functional workspace focused on writing productivity.",
        "pages": [
          {
            "id": "drafts",
            "layout": [
              "drafts-table"
            ],
            "route": "/drafts"
          },
          {
            "id": "editor",
            "layout": [
              "article-editor"
            ],
            "route": "/drafts/:id"
          },
          {
            "id": "published",
            "layout": [
              "published-table"
            ],
            "route": "/published"
          }
        ]
      },
      {
        "id": "content-newsletter",
        "role": "auxiliary",
        "shell": "minimal-header",
        "features": [
          "subscription",
          "email"
        ],
        "description": "Newsletter signup and archive experience. Landing-style subscribe page with hero and contact form, plus a browsable archive of past newsletters.",
        "pages": [
          {
            "id": "subscribe",
            "layout": [
              "subscribe-hero",
              "subscribe-form"
            ],
            "route": "/subscribe"
          },
          {
            "id": "archive",
            "layout": [
              "newsletter-archive"
            ],
            "route": "/newsletter"
          }
        ]
      },
      {
        "id": "marketing-content",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "marketing",
          "seo"
        ],
        "description": "Marketing landing page for a content site with hero, feature highlights, testimonials, and call-to-action sections. Public-facing entry point designed to attract readers and subscribers.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "landing-hero",
              "content-features",
              "reader-testimonials",
              "subscribe-cta"
            ],
            "route": "/"
          }
        ]
      },
      {
        "id": "auth-flow",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth"
        ],
        "description": "Login, registration, and password recovery with OAuth support",
        "pages": [
          {
            "id": "login",
            "layout": [
              "auth-form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              {
                "preset": "register",
                "pattern": "auth-form"
              }
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              {
                "preset": "reset",
                "pattern": "auth-form"
              }
            ],
            "route": "/forgot-password"
          }
        ]
      },
      {
        "id": "settings",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [],
        "description": "Application settings and preferences page",
        "pages": [
          {
            "id": "settings",
            "layout": [
              {
                "preset": "settings",
                "pattern": "form-sections"
              }
            ],
            "route": "/settings"
          }
        ]
      }
    ],
    "features": [
      "search",
      "reading",
      "rss",
      "bookmarks",
      "editing",
      "publishing",
      "auto-save",
      "markdown",
      "subscription",
      "email",
      "marketing",
      "seo",
      "auth",
      "theme-toggle"
    ],
    "routes": {
      "/": {
        "section": "marketing-content",
        "page": "home"
      },
      "/login": {
        "section": "auth-flow",
        "page": "login"
      },
      "/drafts": {
        "section": "content-author",
        "page": "drafts"
      },
      "/articles": {
        "section": "content-reader",
        "page": "articles"
      },
      "/register": {
        "section": "auth-flow",
        "page": "register"
      },
      "/settings": {
        "section": "settings",
        "page": "settings"
      },
      "/published": {
        "section": "content-author",
        "page": "published"
      },
      "/subscribe": {
        "section": "content-newsletter",
        "page": "subscribe"
      },
      "/categories": {
        "section": "content-reader",
        "page": "categories"
      },
      "/drafts/:id": {
        "section": "content-author",
        "page": "editor"
      },
      "/newsletter": {
        "section": "content-newsletter",
        "page": "archive"
      },
      "/articles/:id": {
        "section": "content-reader",
        "page": "article-detail"
      },
      "/forgot-password": {
        "section": "auth-flow",
        "page": "forgot-password"
      }
    }
  },
  "meta": {
    "archetype": "content-reader",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "WebSite",
        "Blog",
        "Article"
      ],
      "meta_priorities": [
        "description",
        "og:title",
        "og:image"
      ]
    },
    "navigation": {
      "hotkeys": [
        {
          "key": "g h",
          "label": "Go to Home",
          "route": "/"
        },
        {
          "key": "g a",
          "label": "Go to Articles",
          "route": "/articles"
        },
        {
          "key": "g c",
          "label": "Go to Categories",
          "route": "/categories"
        },
        {
          "key": "g d",
          "label": "Go to Drafts",
          "route": "/drafts"
        },
        {
          "key": "g n",
          "label": "Go to Newsletter",
          "route": "/newsletter"
        }
      ],
      "command_palette": true
    }
  }
}
