{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "style": "terminal",
      "mode": "dark",
      "recipe": "terminal",
      "shape": "sharp"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "sharp",
      "base": 2
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "subtle",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "technical",
      "retro",
      "focused",
      "immersive"
    ],
    "constraints": {
      "mode": "dark_only",
      "borders": "ascii_box_drawing",
      "corners": "sharp_only",
      "effects": {
        "glow": "optional",
        "flicker": "disabled",
        "scanlines": "optional"
      },
      "shadows": "none",
      "typography": "monospace_only"
    }
  },
  "blueprint": {
    "sections": [
      {
        "id": "terminal-home",
        "role": "primary",
        "shell": "terminal-split",
        "features": [
          "split-panes",
          "log-streaming",
          "metrics",
          "command-input",
          "keyboard-shortcuts",
          "command-palette"
        ],
        "description": "Main terminal dashboard view with split panes, log streaming, metrics, and command input. Core interface for CLI-style developer tools.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "status",
              "main-split",
              "hotkeys"
            ],
            "route": "/app"
          }
        ]
      },
      {
        "id": "log-viewer",
        "role": "auxiliary",
        "shell": "terminal-split",
        "features": [
          "log-streaming",
          "log-filtering",
          "log-search",
          "log-levels",
          "auto-scroll",
          "export-logs"
        ],
        "description": "Dedicated log streaming interface with filtering, search, and real-time updates. Focus view for log analysis and monitoring.",
        "pages": [
          {
            "id": "logs",
            "layout": [
              "status",
              "log-stream",
              "hotkeys"
            ],
            "route": "/app/logs"
          },
          {
            "id": "grouped",
            "layout": [
              "status",
              "grouped-logs",
              "hotkeys"
            ],
            "route": "/app/logs/grouped"
          }
        ]
      },
      {
        "id": "metrics-monitor",
        "role": "auxiliary",
        "shell": "terminal-split",
        "features": [
          "realtime-metrics",
          "ascii-charts",
          "sparklines",
          "threshold-alerts",
          "historical-data"
        ],
        "description": "System metrics dashboard with ASCII charts, gauges, and real-time updates. Terminal-style monitoring interface.",
        "pages": [
          {
            "id": "metrics",
            "layout": [
              "status",
              "quad-split",
              "hotkeys"
            ],
            "route": "/app/metrics"
          },
          {
            "id": "detail",
            "layout": [
              "status",
              "detailed-chart",
              "metric-detail",
              "hotkeys"
            ],
            "route": "/app/metrics/:id"
          }
        ]
      },
      {
        "id": "config-editor",
        "role": "auxiliary",
        "shell": "terminal-split",
        "features": [
          "file-tree",
          "syntax-highlight",
          "diff-view",
          "search-replace",
          "undo-redo",
          "auto-save"
        ],
        "description": "Configuration file editor with tree navigation, diff view, and terminal integration. For managing app configuration in a terminal interface.",
        "pages": [
          {
            "id": "config",
            "layout": [
              "main-split",
              "status",
              "hotkeys"
            ],
            "route": "/app/config"
          },
          {
            "id": "diff",
            "layout": [
              "status",
              "diff",
              "hotkeys"
            ],
            "route": "/app/config/diff"
          }
        ]
      },
      {
        "id": "marketing-devtool",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "terminal-hero",
          "ascii-demo",
          "code-examples",
          "installation-guide"
        ],
        "description": "Developer tool landing page with terminal-styled hero, feature highlights, and ASCII art elements. Marketing page that maintains the terminal aesthetic.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "hero",
              "features",
              "demo-terminal",
              "demo-chart",
              "cta"
            ],
            "route": "/"
          },
          {
            "id": "docs",
            "layout": [
              "documentation",
              "code-examples"
            ],
            "route": "/docs"
          }
        ]
      },
      {
        "id": "auth-full",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth",
          "mfa",
          "oauth",
          "email-verification",
          "password-reset"
        ],
        "description": "Complete authentication flow with login, register, forgot password, reset password, email verification, and MFA setup/verify.",
        "pages": [
          {
            "id": "login",
            "layout": [
              "form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              "form"
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              "form"
            ]
          },
          {
            "id": "reset-password",
            "layout": [
              "form"
            ]
          },
          {
            "id": "verify-email",
            "layout": [
              "form"
            ]
          },
          {
            "id": "mfa-setup",
            "layout": [
              "form"
            ]
          },
          {
            "id": "mfa-verify",
            "layout": [
              "form"
            ]
          },
          {
            "id": "phone-verify",
            "layout": [
              "form"
            ]
          }
        ]
      },
      {
        "id": "legal",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "toc-navigation",
          "print-friendly",
          "smooth-scroll"
        ],
        "description": "Legal pages including privacy policy, terms of service, and cookie policy with sticky TOC and print-friendly layout.",
        "pages": [
          {
            "id": "privacy",
            "layout": [
              "content"
            ],
            "route": "/privacy"
          },
          {
            "id": "terms",
            "layout": [
              "content"
            ],
            "route": "/terms"
          },
          {
            "id": "cookies",
            "layout": [
              "content"
            ]
          }
        ]
      }
    ],
    "features": [
      "split-panes",
      "log-streaming",
      "metrics",
      "command-input",
      "keyboard-shortcuts",
      "command-palette",
      "log-filtering",
      "log-search",
      "log-levels",
      "auto-scroll",
      "export-logs",
      "realtime-metrics",
      "ascii-charts",
      "sparklines",
      "threshold-alerts",
      "historical-data",
      "file-tree",
      "syntax-highlight",
      "diff-view",
      "search-replace",
      "undo-redo",
      "auto-save",
      "terminal-hero",
      "ascii-demo",
      "code-examples",
      "installation-guide",
      "auth",
      "mfa",
      "oauth",
      "email-verification",
      "password-reset",
      "toc-navigation",
      "print-friendly",
      "smooth-scroll"
    ],
    "routes": {
      "/": {
        "section": "marketing-devtool",
        "page": "home"
      },
      "/app": {
        "section": "terminal-home",
        "page": "home"
      },
      "/docs": {
        "section": "marketing-devtool",
        "page": "docs"
      },
      "/login": {
        "section": "auth-full",
        "page": "login"
      },
      "/terms": {
        "section": "legal",
        "page": "terms"
      },
      "/privacy": {
        "section": "legal",
        "page": "privacy"
      },
      "/app/logs": {
        "section": "log-viewer",
        "page": "logs"
      },
      "/register": {
        "section": "auth-full",
        "page": "register"
      },
      "/app/config": {
        "section": "config-editor",
        "page": "config"
      },
      "/app/metrics": {
        "section": "metrics-monitor",
        "page": "metrics"
      },
      "/app/config/diff": {
        "section": "config-editor",
        "page": "diff"
      },
      "/app/metrics/:id": {
        "section": "metrics-monitor",
        "page": "detail"
      },
      "/app/logs/grouped": {
        "section": "log-viewer",
        "page": "grouped"
      }
    }
  },
  "meta": {
    "archetype": "terminal-home",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "WebApplication",
        "SoftwareApplication"
      ],
      "meta_priorities": [
        "description",
        "og:image",
        "twitter:card"
      ]
    },
    "navigation": {
      "hotkeys": [
        {
          "key": "F1",
          "label": "Home",
          "route": "/app"
        },
        {
          "key": "F2",
          "label": "Config",
          "route": "/app/config"
        },
        {
          "key": "F3",
          "label": "Logs",
          "route": "/app/logs"
        },
        {
          "key": "F4",
          "label": "Metrics",
          "route": "/app/metrics"
        },
        {
          "key": "F10",
          "label": "Quit",
          "action": "logout"
        }
      ],
      "command_palette": true
    }
  }
}
