{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "paper",
      "mode": "light",
      "shape": "rounded"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "rounded",
      "base": 8
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "subtle",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Warm, distraction-free collaboration workspace built for focused teamwork. Light paper-like backgrounds with comfortable reading typography. Presence indicators use distinct warm colors per collaborator. Inline comments appear as subtle margin annotations. Page tree navigation is clean and collapsible. The document editor prioritizes content over chrome — toolbar hides on scroll, formatting is keyboard-first. Real-time cursors and selections feel natural, not distracting. Think Notion meets Google Docs — productive, polished, and genuinely collaborative."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "workspace-home",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "realtime",
          "search",
          "favorites",
          "recent-history"
        ],
        "description": "Dashboard for collaborative workspace with recent documents, shared items, and activity feed. Landing page after login.",
        "pages": [
          {
            "id": "dashboard",
            "layout": [
              "notifications",
              "activity-feed",
              "recent-docs",
              "shared-docs",
              "task-board"
            ],
            "route": "/home"
          }
        ]
      },
      {
        "id": "document-editor",
        "role": "primary",
        "shell": "workspace-aside",
        "features": [
          "realtime",
          "presence",
          "comments",
          "mentions",
          "versioning",
          "sharing",
          "export",
          "markdown",
          "slash-commands"
        ],
        "description": "Real-time collaborative document editing with presence indicators, remote cursors, inline comments, and version history.",
        "pages": [
          {
            "id": "doc",
            "layout": [
              "doc-breadcrumbs",
              "nav-header",
              "presence-avatars",
              "doc-editor",
              "reactions",
              "comments"
            ],
            "route": "/doc/:id"
          }
        ]
      },
      {
        "id": "workspace-settings",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "team-management",
          "permissions",
          "billing",
          "admin"
        ],
        "description": "Team workspace configuration including general settings, member management, permissions, and billing.",
        "pages": [
          {
            "id": "general",
            "layout": [
              "workspace-info"
            ],
            "route": "/settings"
          },
          {
            "id": "members",
            "layout": [
              "data-table",
              "invite"
            ],
            "route": "/settings/members"
          },
          {
            "id": "permissions",
            "layout": [
              "permissions"
            ],
            "route": "/settings/permissions"
          },
          {
            "id": "billing",
            "layout": [
              "plan",
              "billing-info"
            ],
            "route": "/settings/billing"
          }
        ]
      },
      {
        "id": "auth-full",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth",
          "mfa",
          "oauth",
          "email-verification",
          "password-reset"
        ],
        "description": "Complete authentication flow with login, register, forgot password, reset password, email verification, and MFA setup/verify.",
        "pages": [
          {
            "id": "login",
            "layout": [
              "form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              "form"
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              "form"
            ],
            "route": "/forgot-password"
          },
          {
            "id": "reset-password",
            "layout": [
              "form"
            ],
            "route": "/reset-password"
          },
          {
            "id": "verify-email",
            "layout": [
              "form"
            ],
            "route": "/verify-email"
          },
          {
            "id": "mfa-setup",
            "layout": [
              "form"
            ],
            "route": "/mfa-setup"
          },
          {
            "id": "mfa-verify",
            "layout": [
              "form"
            ],
            "route": "/mfa-verify"
          },
          {
            "id": "phone-verify",
            "layout": [
              "form"
            ]
          }
        ]
      },
      {
        "id": "settings-full",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "profile-edit",
          "password-change",
          "mfa-management",
          "session-management",
          "theme-toggle",
          "account-deletion"
        ],
        "description": "Complete account settings with profile, security (password, MFA, sessions), preferences (theme, notifications, language), and danger zone.",
        "pages": [
          {
            "id": "profile",
            "layout": [
              "account-settings"
            ],
            "route": "/profile"
          },
          {
            "id": "security",
            "layout": [
              "account-settings",
              "sessions"
            ],
            "route": "/profile/security"
          },
          {
            "id": "preferences",
            "layout": [
              "account-settings"
            ],
            "route": "/profile/preferences"
          },
          {
            "id": "danger",
            "layout": [
              "account-settings"
            ]
          }
        ]
      },
      {
        "id": "marketing-productivity",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "marketing",
          "pricing",
          "testimonials",
          "cta"
        ],
        "description": "Marketing landing page for productivity and collaboration tools. Features hero, feature grid, collaboration showcase, pricing, and testimonials.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "hero",
              "features",
              "collaboration-demo",
              "pricing",
              "testimonials",
              "cta"
            ],
            "route": "/"
          },
          {
            "id": "pricing",
            "layout": [
              "hero",
              "pricing",
              "cta"
            ],
            "route": "/pricing"
          }
        ]
      },
      {
        "id": "about-hybrid",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "team-grid",
          "values-display"
        ],
        "description": "About page combining hero, company story, team grid, values, and call-to-action sections.",
        "pages": [
          {
            "id": "about",
            "layout": [
              "hero",
              "story",
              "team",
              "values",
              "cta"
            ],
            "route": "/about"
          }
        ]
      },
      {
        "id": "contact",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "form-validation",
          "spam-protection",
          "file-attachment"
        ],
        "description": "Contact page with hero header and working contact form with validation and spam protection.",
        "pages": [
          {
            "id": "contact",
            "layout": [
              "hero",
              "form"
            ],
            "route": "/contact"
          }
        ]
      },
      {
        "id": "legal",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "toc-navigation",
          "print-friendly",
          "smooth-scroll"
        ],
        "description": "Legal pages including privacy policy, terms of service, and cookie policy with sticky TOC and print-friendly layout.",
        "pages": [
          {
            "id": "privacy",
            "layout": [
              "legal-prose"
            ],
            "route": "/privacy"
          },
          {
            "id": "terms",
            "layout": [
              "legal-prose"
            ],
            "route": "/terms"
          },
          {
            "id": "cookies",
            "layout": [
              "legal-prose"
            ]
          }
        ]
      }
    ],
    "features": [
      "realtime",
      "search",
      "favorites",
      "recent-history",
      "presence",
      "comments",
      "mentions",
      "versioning",
      "sharing",
      "export",
      "markdown",
      "slash-commands",
      "team-management",
      "permissions",
      "billing",
      "admin",
      "auth",
      "mfa",
      "oauth",
      "email-verification",
      "password-reset",
      "profile-edit",
      "password-change",
      "mfa-management",
      "session-management",
      "theme-toggle",
      "account-deletion",
      "marketing",
      "pricing",
      "testimonials",
      "cta",
      "team-grid",
      "values-display",
      "form-validation",
      "spam-protection",
      "file-attachment",
      "toc-navigation",
      "print-friendly",
      "smooth-scroll"
    ],
    "routes": {
      "/": {
        "section": "marketing-productivity",
        "page": "home"
      },
      "/home": {
        "section": "workspace-home",
        "page": "dashboard"
      },
      "/team": {
        "section": "workspace-settings",
        "page": "members"
      },
      "/about": {
        "section": "about-hybrid",
        "page": "about"
      },
      "/login": {
        "section": "auth-full",
        "page": "login"
      },
      "/terms": {
        "section": "legal",
        "page": "terms"
      },
      "/contact": {
        "section": "contact",
        "page": "contact"
      },
      "/doc/:id": {
        "section": "document-editor",
        "page": "doc"
      },
      "/pricing": {
        "section": "marketing-productivity",
        "page": "pricing"
      },
      "/privacy": {
        "section": "legal",
        "page": "privacy"
      },
      "/profile": {
        "section": "settings-full",
        "page": "profile"
      },
      "/register": {
        "section": "auth-full",
        "page": "register"
      },
      "/settings": {
        "section": "workspace-settings",
        "page": "general"
      },
      "/mfa-setup": {
        "section": "auth-full",
        "page": "mfa-setup"
      },
      "/mfa-verify": {
        "section": "auth-full",
        "page": "mfa-verify"
      },
      "/verify-email": {
        "section": "auth-full",
        "page": "verify-email"
      },
      "/reset-password": {
        "section": "auth-full",
        "page": "reset-password"
      },
      "/forgot-password": {
        "section": "auth-full",
        "page": "forgot-password"
      },
      "/profile/security": {
        "section": "settings-full",
        "page": "security"
      },
      "/settings/billing": {
        "section": "workspace-settings",
        "page": "billing"
      },
      "/settings/members": {
        "section": "workspace-settings",
        "page": "members"
      },
      "/profile/preferences": {
        "section": "settings-full",
        "page": "preferences"
      },
      "/settings/permissions": {
        "section": "workspace-settings",
        "page": "permissions"
      }
    }
  },
  "meta": {
    "archetype": "workspace-home",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "WebApplication",
        "SoftwareApplication",
        "CollaborativeWorkspace"
      ],
      "meta_priorities": [
        "description",
        "og:image",
        "twitter:card"
      ]
    },
    "navigation": {
      "hotkeys": [
        {
          "key": "g h",
          "label": "Go to Home",
          "route": "/home"
        },
        {
          "key": "g s",
          "label": "Go to Settings",
          "route": "/settings"
        },
        {
          "key": "g t",
          "label": "Go to Team",
          "route": "/team"
        }
      ],
      "command_palette": true
    }
  }
}
