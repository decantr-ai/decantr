{
  "version": "3.1.0",
  "dna": {
    "theme": {
      "id": "gaming-guild",
      "mode": "dark",
      "shape": "rounded"
    },
    "spacing": {
      "base_unit": 4,
      "scale": "linear",
      "density": "comfortable",
      "content_gap": "_gap4"
    },
    "typography": {
      "scale": "modular",
      "heading_weight": 600,
      "body_weight": 400
    },
    "color": {
      "palette": "semantic",
      "accent_count": 1,
      "cvd_preference": "auto"
    },
    "radius": {
      "philosophy": "rounded",
      "base": 8
    },
    "elevation": {
      "system": "layered",
      "max_levels": 3
    },
    "motion": {
      "preference": "subtle",
      "duration_scale": 1,
      "reduce_motion": true
    },
    "accessibility": {
      "wcag_level": "AA",
      "focus_visible": true,
      "skip_nav": true
    },
    "personality": [
      "Professional esports team operations hub with vibrant neon-accented rosters and live scoreboards. Player form trackers show sparklines of K/D ratios, win rates, and self-reported mood indicators. Scrim calendars map team availability to opponent windows. VOD review interface with frame-by-frame annotations and drawing tools. Sponsor dashboards track activation metrics. Think Overwatch League backstage. Lucide icons. Competitive."
    ]
  },
  "blueprint": {
    "sections": [
      {
        "id": "team-operations",
        "role": "primary",
        "shell": "sidebar-main",
        "features": [
          "team-management",
          "rosters"
        ],
        "description": "Primary esports team operations surface with team overview dashboard, player roster, and individual player profiles tracking form and activity.",
        "pages": [
          {
            "id": "overview",
            "layout": [
              "kpi-grid",
              "scoreboard-live",
              "activity-feed"
            ],
            "route": "/team"
          },
          {
            "id": "roster",
            "layout": [
              "player-form-tracker",
              "card-grid"
            ],
            "route": "/team/roster"
          },
          {
            "id": "player-detail",
            "layout": [
              "player-form-tracker",
              "chart-grid",
              "activity-feed"
            ],
            "route": "/team/players/:id"
          }
        ]
      },
      {
        "id": "scrim-scheduler",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "scheduling",
          "calendars"
        ],
        "description": "Auxiliary esports scheduling surface for managing scrim calendars and inspecting match detail with live scoreboards and timelines.",
        "pages": [
          {
            "id": "scrims",
            "layout": [
              "scrim-calendar",
              "data-table"
            ],
            "route": "/scrims"
          },
          {
            "id": "match-detail",
            "layout": [
              "detail-header",
              "scoreboard-live",
              "timeline"
            ],
            "route": "/scrims/:id"
          }
        ]
      },
      {
        "id": "vod-review",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "vod-review",
          "annotations"
        ],
        "description": "Auxiliary esports VOD review surface for browsing a library of match recordings and annotating frames with coaching notes and timestamps.",
        "pages": [
          {
            "id": "vods",
            "layout": [
              "data-table",
              "card-grid"
            ],
            "route": "/vods"
          },
          {
            "id": "vod-detail",
            "layout": [
              "vod-annotator",
              "timeline"
            ],
            "route": "/vods/:id"
          }
        ]
      },
      {
        "id": "sponsor-dashboard",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "sponsors",
          "deals"
        ],
        "description": "Auxiliary esports sponsor surface for managing brand partnerships, tracking deal value, impressions, and activation metrics across sponsors.",
        "pages": [
          {
            "id": "sponsors",
            "layout": [
              "data-table",
              "card-grid"
            ],
            "route": "/sponsors"
          },
          {
            "id": "sponsor-detail",
            "layout": [
              "detail-header",
              "kpi-grid",
              "chart-grid"
            ],
            "route": "/sponsors/:id"
          }
        ]
      },
      {
        "id": "marketing-esports",
        "role": "public",
        "shell": "top-nav-footer",
        "features": [
          "marketing"
        ],
        "description": "Public marketing landing surface for an esports team operations platform with image-overlay hero, feature grid, testimonials, and final call to action.",
        "pages": [
          {
            "id": "home",
            "layout": [
              "hero",
              "features",
              "testimonials",
              "cta-section"
            ],
            "route": "/"
          }
        ]
      },
      {
        "id": "auth-full",
        "role": "gateway",
        "shell": "centered",
        "features": [
          "auth",
          "mfa",
          "oauth",
          "email-verification",
          "password-reset"
        ],
        "description": "Complete authentication flow with login, register, forgot password, reset password, email verification, and MFA setup/verify.",
        "pages": [
          {
            "id": "login",
            "layout": [
              "form"
            ],
            "route": "/login"
          },
          {
            "id": "register",
            "layout": [
              "form"
            ],
            "route": "/register"
          },
          {
            "id": "forgot-password",
            "layout": [
              "form"
            ],
            "route": "/forgot-password"
          },
          {
            "id": "reset-password",
            "layout": [
              "form"
            ],
            "route": "/reset-password"
          },
          {
            "id": "verify-email",
            "layout": [
              "form"
            ],
            "route": "/verify-email"
          },
          {
            "id": "mfa-setup",
            "layout": [
              "form"
            ],
            "route": "/mfa-setup"
          },
          {
            "id": "mfa-verify",
            "layout": [
              "form"
            ],
            "route": "/mfa-verify"
          },
          {
            "id": "phone-verify",
            "layout": [
              "form"
            ],
            "route": "/phone-verify"
          }
        ]
      },
      {
        "id": "settings-full",
        "role": "auxiliary",
        "shell": "sidebar-main",
        "features": [
          "profile-edit",
          "password-change",
          "mfa-management",
          "session-management",
          "theme-toggle",
          "account-deletion"
        ],
        "description": "Complete account settings with profile, security (password, MFA, sessions), preferences (theme, notifications, language), and danger zone.",
        "pages": [
          {
            "id": "profile",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/profile"
          },
          {
            "id": "security",
            "layout": [
              "account-settings",
              "sessions"
            ],
            "route": "/settings/security"
          },
          {
            "id": "preferences",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/preferences"
          },
          {
            "id": "danger",
            "layout": [
              "account-settings"
            ],
            "route": "/settings/danger"
          }
        ]
      }
    ],
    "features": [
      "team-management",
      "rosters",
      "scheduling",
      "calendars",
      "vod-review",
      "annotations",
      "sponsors",
      "deals",
      "marketing",
      "auth",
      "mfa",
      "oauth",
      "email-verification",
      "password-reset",
      "profile-edit",
      "password-change",
      "mfa-management",
      "session-management",
      "theme-toggle",
      "account-deletion"
    ],
    "routes": {
      "/": {
        "section": "marketing-esports",
        "page": "home"
      },
      "/team": {
        "section": "team-operations",
        "page": "overview"
      },
      "/vods": {
        "section": "vod-review",
        "page": "vods"
      },
      "/login": {
        "section": "auth-full",
        "page": "login"
      },
      "/scrims": {
        "section": "scrim-scheduler",
        "page": "scrims"
      },
      "/register": {
        "section": "auth-full",
        "page": "register"
      },
      "/sponsors": {
        "section": "sponsor-dashboard",
        "page": "sponsors"
      },
      "/vods/:id": {
        "section": "vod-review",
        "page": "vod-detail"
      },
      "/mfa-setup": {
        "section": "auth-full",
        "page": "mfa-setup"
      },
      "/mfa-verify": {
        "section": "auth-full",
        "page": "mfa-verify"
      },
      "/scrims/:id": {
        "section": "scrim-scheduler",
        "page": "match-detail"
      },
      "/team/roster": {
        "section": "team-operations",
        "page": "roster"
      },
      "/phone-verify": {
        "section": "auth-full",
        "page": "phone-verify"
      },
      "/sponsors/:id": {
        "section": "sponsor-dashboard",
        "page": "sponsor-detail"
      },
      "/verify-email": {
        "section": "auth-full",
        "page": "verify-email"
      },
      "/reset-password": {
        "section": "auth-full",
        "page": "reset-password"
      },
      "/forgot-password": {
        "section": "auth-full",
        "page": "forgot-password"
      },
      "/settings/danger": {
        "section": "settings-full",
        "page": "danger"
      },
      "/settings/profile": {
        "section": "settings-full",
        "page": "profile"
      },
      "/team/players/:id": {
        "section": "team-operations",
        "page": "player-detail"
      },
      "/settings/security": {
        "section": "settings-full",
        "page": "security"
      },
      "/settings/preferences": {
        "section": "settings-full",
        "page": "preferences"
      }
    }
  },
  "meta": {
    "archetype": "team-operations",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Organization",
        "SportsTeam"
      ],
      "meta_priorities": [
        "description",
        "og:image"
      ]
    },
    "navigation": {
      "hotkeys": [],
      "command_palette": true
    }
  }
}
