  "meta": {
    "archetype": "restaurant-floor",
    "target": "react",
    "platform": {
      "type": "spa",
      "routing": "hash"
    },
    "guard": {
      "mode": "strict",
      "dna_enforcement": "error",
      "blueprint_enforcement": "warn"
    },
    "seo": {
      "schema_org": [
        "Restaurant",
        "Organization"
      ],
      "meta_priorities": [
        "description",
        "og:image"
      ]
    },
    "navigation": {
