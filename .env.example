# Decantr Project Environment
# Copy to .env: cp .env.example .env

# Override registry URL (e.g. for local dev server)
# DECANTR_REGISTRY_URL=http://localhost:3000/v1

# Figma sync token (or pass via --token flag)
# FIGMA_TOKEN=

# Enable LLM integration tests
# DECANTR_TEST_LLM=1
# ANTHROPIC_API_KEY=
