{
  "version": "2.0.0",
  "archetype": "saas-dashboard",
  "theme": { "style": "auradecantism", "mode": "dark", "recipe": "auradecantism" },
  "personality": ["professional", "data-rich"],
  "platform": { "type": "spa", "routing": "hash" },
  "structure": [
    {
      "id": "overview",
      "shell": "sidebar-main",
      "layout": ["kpi-grid", { "cols": ["filter-bar", "data-table"], "at": "lg" }]
    },
    {
      "id": "settings",
      "shell": "sidebar-main",
      "layout": [{ "pattern": "form-sections", "preset": "settings" }]
    }
  ],
  "features": ["auth"],
  "density": { "level": "comfortable", "content_gap": "4" },
  "guard": { "enforce_style": true, "enforce_recipe": true, "mode": "strict" },
  "target": "decantr"
}
