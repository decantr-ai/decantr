{
  "version": "3.0.0",
  "dna": {
    "theme": { "style": "auradecantism", "mode": "dark" },
    "spacing": { "base_unit": 4, "scale": "linear", "density": "comfortable", "content_gap": "4" },
    "typography": { "scale": "major-third", "heading_weight": 700, "body_weight": 400 },
    "color": { "palette": "neutral", "accent_count": 1, "cvd_preference": "none" },
    "radius": { "philosophy": "rounded", "base": 8 },
    "elevation": { "system": "subtle", "max_levels": 3 },
    "motion": { "preference": "full", "duration_scale": 1, "reduce_motion": false },
    "accessibility": { "wcag_level": "AA", "focus_visible": true, "skip_nav": true },
    "personality": ["technical", "minimal"]
  },
  "blueprint": {
    "pages": [{ "id": "home", "shell": "marketing", "layout": ["hero", "content-section"] }],
    "features": []
  },
  "meta": {
    "archetype": "documentation-site",
    "target": "browser",
    "platform": { "type": "static", "routing": "history" },
    "guard": { "mode": "creative", "dna_enforcement": "off", "blueprint_enforcement": "off" }
  }
}
