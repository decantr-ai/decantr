{
  "name": "@decantr/cli",
  "version": "1.7.5",
  "description": "Decantr CLI — scaffold, audit, and maintain Decantr projects from the terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/decantr-ai/decantr.git",
    "directory": "packages/cli"
  },
  "homepage": "https://decantr.ai",
  "type": "module",
  "bin": {
    "decantr": "./dist/bin.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "src/templates",
    "src/bundled"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@decantr/core": "workspace:*",
    "@decantr/essence-spec": "workspace:*",
    "@decantr/registry": "workspace:*",
    "@decantr/verifier": "workspace:*"
  }
}
