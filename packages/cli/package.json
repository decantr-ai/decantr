{
  "name": "@decantr/cli",
  "version": "1.7.15",
  "description": "Decantr CLI — scaffold, audit, and maintain Decantr projects from the terminal",
  "author": "Decantr AI",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/decantr-ai/decantr/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decantr-ai/decantr.git",
    "directory": "packages/cli"
  },
  "homepage": "https://decantr.ai",
  "type": "module",
  "bin": {
    "decantr": "dist/bin.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "src/templates",
    "src/bundled"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "certify:blueprints": "pnpm build && node scripts/certify-blueprints.mjs",
    "certify:workflows": "pnpm build && node scripts/certify-workflows.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "preversion": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@decantr/core": "workspace:*",
    "@decantr/essence-spec": "workspace:*",
    "@decantr/registry": "workspace:*",
    "@decantr/verifier": "workspace:*"
  }
}
