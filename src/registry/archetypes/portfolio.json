{
  "$schema": "https://decantr.ai/schemas/archetype.v1.json",
  "id": "portfolio",
  "name": "Portfolio",
  "description": "Personal or agency portfolio showcasing work, skills, and contact information.",
  "pages": [
    {
      "id": "home",
      "skeleton": "full-bleed",
      "patterns": ["hero", "component-showcase", "testimonials", "cta-section"],
      "default_blend": [
        "hero",
        "component-showcase",
        "testimonials",
        "cta-section"
      ]
    },
    {
      "id": "about",
      "skeleton": "top-nav-main",
      "patterns": ["detail-header", "timeline"],
      "default_blend": [
        "detail-header",
        "timeline"
      ]
    },
    {
      "id": "projects",
      "skeleton": "top-nav-main",
      "patterns": ["filter-bar", "media-gallery"],
      "default_blend": [
        "filter-bar",
        "media-gallery"
      ]
    },
    {
      "id": "project-detail",
      "skeleton": "top-nav-main",
      "patterns": ["media-gallery", "detail-panel"],
      "default_blend": [
        "media-gallery",
        "detail-panel"
      ]
    },
    {
      "id": "blog",
      "skeleton": "top-nav-main",
      "patterns": ["post-list", "category-nav", "pagination"],
      "default_blend": [
        "category-nav",
        "post-list",
        "pagination"
      ]
    },
    {
      "id": "blog-post",
      "skeleton": "top-nav-main",
      "patterns": ["article-content", "author-card", "table-of-contents"],
      "default_blend": [
        { "cols": ["article-content", "table-of-contents"], "span": { "article-content": 3 }, "at": "lg" },
        "author-card"
      ]
    },
    {
      "id": "contact",
      "skeleton": "top-nav-main",
      "patterns": ["contact-form"],
      "default_blend": [
        "contact-form"
      ]
    }
  ],
  "tannins": ["contact-form", "blog-state", "analytics"],
  "skeletons": {
    "full-bleed": "No persistent navigation — hero-first, scroll-driven sections",
    "top-nav-main": "Horizontal navigation bar + full-width main content area"
  },
  "suggested_vintage": {
    "styles": ["auradecantism", "glassmorphism", "retro"],
    "modes": ["dark", "auto"]
  }
}
