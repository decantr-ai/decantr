{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "portfolio",
  "name": "Portfolio",
  "description": "Single-page brand landing site with stunning hero, feature showcase, social proof, and conversion-focused layout.",
  "pages": [
    {
      "id": "home",
      "skeleton": "full-bleed",
      "patterns": [
        "announcement-bar",
        "hero",
        "logo-strip",
        "card-grid",
        "code-preview",
        "stats-section",
        "testimonials",
        "showcase-gallery",
        "cta-section",
        "footer-columns"
      ],
      "default_blend": [
        "announcement-bar",
        { "pattern": "hero", "preset": "brand", "as": "brand-hero" },
        { "pattern": "logo-strip", "preset": "marquee", "as": "partner-logos" },
        { "pattern": "card-grid", "preset": "icon", "as": "feature-grid" },
        { "pattern": "code-preview", "preset": "split", "as": "quickstart" },
        { "pattern": "stats-section", "preset": "hero", "as": "metrics" },
        { "pattern": "testimonials", "preset": "wall", "as": "social-proof" },
        "showcase-gallery",
        { "pattern": "cta-section", "preset": "brand", "as": "final-cta" },
        "footer-columns"
      ]
    }
  ],
  "tannins": ["analytics"],
  "skeletons": {
    "full-bleed": "Floating nav over scroll-driven sections — hero-first, maximum visual impact"
  },
  "suggested_vintage": {
    "styles": ["auradecantism", "glassmorphism", "command-center"],
    "modes": ["dark"]
  }
}
