{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "creative-tool",
  "name": "Creative Tool",
  "description": "Interactive creative tool with brand landing page and sidebar-main workspace. Designed for generators, editors, and explorers — input-driven specimen grids, gallery browsing, and detail inspection.",
  "pages": [
    {
      "id": "home",
      "skeleton": "full-bleed",
      "patterns": [
        "hero",
        "card-grid",
        "stats-section",
        "testimonials",
        "cta-section",
        "footer-columns"
      ],
      "default_blend": [
        { "pattern": "hero", "preset": "brand", "as": "brand-hero" },
        { "pattern": "card-grid", "preset": "icon", "as": "feature-grid" },
        { "pattern": "stats-section", "preset": "hero", "as": "metrics" },
        { "pattern": "testimonials", "preset": "marquee", "as": "social-proof" },
        { "pattern": "cta-section", "preset": "brand", "as": "final-cta" },
        { "pattern": "footer-columns", "preset": "minimal", "as": "footer" }
      ]
    },
    {
      "id": "workspace",
      "skeleton": "sidebar-main",
      "patterns": [
        "search-bar",
        "filter-bar",
        { "pattern": "specimen-grid", "preset": "preview", "as": "palette-grid" }
      ],
      "default_blend": [
        "search-bar",
        "filter-bar",
        { "pattern": "specimen-grid", "preset": "preview", "as": "palette-grid" }
      ]
    },
    {
      "id": "explore",
      "skeleton": "sidebar-main",
      "patterns": [
        "filter-bar",
        { "pattern": "card-grid", "preset": "collection", "as": "palette-gallery" }
      ],
      "default_blend": [
        "filter-bar",
        { "pattern": "card-grid", "preset": "collection", "as": "palette-gallery" }
      ]
    },
    {
      "id": "detail",
      "skeleton": "sidebar-main",
      "patterns": [
        "detail-header",
        { "pattern": "specimen-grid", "preset": "preview", "as": "palette-preview" },
        "comparison-panel"
      ],
      "default_blend": [
        "detail-header",
        { "pattern": "specimen-grid", "preset": "preview", "as": "palette-preview" },
        "comparison-panel"
      ]
    }
  ],
  "tannins": ["search"],
  "skeletons": {
    "full-bleed": "Floating nav over scroll-driven sections — hero-first, maximum visual impact",
    "sidebar-main": "Left sidebar with grouped nav (TOOLS + LIBRARY sections) + main content area"
  },
  "suggested_vintage": {
    "styles": ["clay", "clean", "glassmorphism"],
    "modes": ["light"]
  }
}
