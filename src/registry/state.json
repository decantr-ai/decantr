{
  "module": "decantr/state",
  "description": "Reactive primitives — signals, effects, memos, stores, batch",
  "functions": {
    "createSignal": {
      "params": [
        {
          "name": "initialValue",
          "type": "T"
        }
      ],
      "returns": "[() => T, (v: T | ((prev: T) => T)) => void]"
    },
    "createEffect": {
      "params": [
        {
          "name": "fn",
          "type": "Function"
        }
      ],
      "returns": "Function"
    },
    "createMemo": {
      "params": [
        {
          "name": "fn",
          "type": "() => T"
        }
      ],
      "returns": "() => T"
    },
    "untrack": {
      "params": [
        {
          "name": "initialValue",
          "type": "T"
        }
      ],
      "returns": "T"
    },
    "peek": {
      "params": [
        {
          "name": "getter",
          "type": "() => T"
        }
      ],
      "returns": "T",
      "description": "Read a signal getter without subscribing. Alias for untrack(). Aligns with TC39 Signals proposal terminology."
    },
    "useLocalStorage": {
      "params": [
        {
          "name": "key",
          "type": "string",
          "description": "localStorage key"
        },
        {
          "name": "initialValue",
          "type": "T",
          "description": "fallback if no stored value"
        }
      ],
      "returns": "[() => T, (v: T | ((prev: T) => T)) => void]"
    },
    "createResource": {
      "params": [
        {
          "name": "fetcher",
          "type": "() => Promise<T>"
        },
        {
          "name": "options",
          "type": "{ initialValue?: T, lazy?: boolean }",
          "optional": true
        }
      ],
      "returns": "{ data: () => T|undefined, loading: () => boolean, error: () => Error|null, refetch: () => Promise<void>, mutate: (v: T) => void }"
    },
    "createContext": {
      "params": [
        {
          "name": "defaultValue",
          "type": "T",
          "optional": true
        }
      ],
      "returns": "{ Provider: (value: T) => (() => void), consume: () => T }"
    },
    "createSelector": {
      "params": [
        {
          "name": "source",
          "type": "() => T"
        }
      ],
      "returns": "(key: U) => boolean"
    },
    "createDeferred": {
      "params": [
        {
          "name": "fn",
          "type": "() => T"
        }
      ],
      "returns": "() => T"
    },
    "createHistory": {
      "params": [
        {
          "name": "signal",
          "type": "[() => T, (v: T) => void]"
        },
        {
          "name": "options",
          "type": "{ maxLength?: number }",
          "optional": true
        }
      ],
      "returns": "{ undo: () => void, redo: () => void, canUndo: () => boolean, canRedo: () => boolean, clear: () => void }"
    },
    "batch": {
      "params": [
        {
          "name": "fn",
          "type": "Function"
        }
      ]
    }
  }
}
