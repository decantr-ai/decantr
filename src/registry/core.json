{
  "$schema": "https://decantr.ai/schemas/module.v1.json",
  "module": "decantr/core",
  "description": "DOM engine — hyperscript rendering, conditional, list, mount, lifecycle",
  "functions": {
    "h": {
      "params": [
        {
          "name": "tag",
          "type": "string"
        },
        {
          "name": "props",
          "type": "Object|null"
        },
        {
          "name": "children",
          "type": "...(string|number|Node|Function)"
        }
      ],
      "returns": "HTMLElement"
    },
    "text": {
      "params": [
        {
          "name": "getter",
          "type": "Function|string",
          "description": "A function returning the text value, or a static string"
        }
      ],
      "returns": "Text"
    },
    "cond": {
      "params": [
        {
          "name": "condition",
          "type": "Function"
        },
        {
          "name": "thenFn",
          "type": "Function"
        },
        {
          "name": "elseFn",
          "type": "Function",
          "optional": true
        }
      ],
      "returns": "HTMLElement"
    },
    "list": {
      "params": [
        {
          "name": "itemsGetter",
          "type": "Function"
        },
        {
          "name": "keyFn",
          "type": "Function"
        },
        {
          "name": "renderFn",
          "type": "Function"
        }
      ],
      "returns": "HTMLElement"
    },
    "mount": {
      "params": [
        {
          "name": "root",
          "type": "HTMLElement"
        },
        {
          "name": "component",
          "type": "Function"
        }
      ]
    },
    "unmount": {
      "params": [
        {
          "name": "root",
          "type": "HTMLElement"
        }
      ],
      "description": "Unmount a previously mounted component tree."
    },
    "setErrorHandler": {
      "params": [
        {
          "name": "fn",
          "type": "(info: { error: Error, component: string|null, stack: string|null, context: Object }) => void"
        }
      ],
      "description": "Set a global error telemetry handler. Called whenever an ErrorBoundary catches an error."
    },
    "_getErrorHandler": {
      "returns": "Function|null",
      "description": "Get the current error telemetry handler (for testing/internal use)."
    },
    "_getBoundaryHandler": {
      "returns": "Function|null",
      "description": "Get the current boundary error handler (used by effect patching)."
    },
    "ErrorBoundary": {
      "params": [
        {
          "name": "props",
          "type": "Object"
        },
        {
          "name": "props.fallback",
          "type": "Function"
        },
        {
          "name": "children",
          "type": "...Node"
        }
      ],
      "returns": "HTMLElement",
      "description": "Error catching component. Wraps children in try/catch during render. Also catches errors thrown inside createEffect within its subtree."
    },
    "Portal": {
      "params": [
        {
          "name": "props",
          "type": "Object"
        },
        {
          "name": "props.target",
          "type": "HTMLElement|string",
          "optional": true
        },
        {
          "name": "children",
          "type": "...Node"
        }
      ],
      "returns": "Comment",
      "description": "Render children outside the component tree into a target element."
    },
    "Suspense": {
      "params": [
        {
          "name": "props",
          "type": "Object"
        },
        {
          "name": "props.fallback",
          "type": "Function"
        },
        {
          "name": "children",
          "type": "...Node"
        }
      ],
      "returns": "HTMLElement",
      "description": "Async boundary. Shows fallback while any createQuery() in children is loading."
    },
    "Transition": {
      "params": [
        {
          "name": "props",
          "type": "Object"
        },
        {
          "name": "props.enter",
          "type": "string",
          "optional": true
        },
        {
          "name": "props.exit",
          "type": "string",
          "optional": true
        },
        {
          "name": "props.duration=200",
          "type": "number",
          "optional": true
        },
        {
          "name": "child",
          "type": "Function"
        }
      ],
      "returns": "HTMLElement",
      "description": "Enter/exit animation wrapper for conditional content."
    },
    "forwardRef": {
      "params": [
        {
          "name": "component",
          "type": "Function"
        }
      ],
      "returns": "Function",
      "description": "Extract ref from props and pass it as second argument to a component."
    },
    "onMount": {
      "params": [
        {
          "name": "fn",
          "type": "Function"
        }
      ]
    }
  }
}
