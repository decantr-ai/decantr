    "showcase-gallery": { "name": "Showcase Gallery", "file": "showcase-gallery.json", "presets": ["screenshots", "cards"] },
    "showcase-card": { "name": "Showcase Card", "file": "showcase-card.json", "presets": ["app", "compact"] },
    "footer-columns": { "name": "Footer Columns", "file": "footer-columns.json", "presets": ["standard", "minimal"] },
    "kanban-board": { "name": "Kanban Board", "file": "kanban-board.json" },
    "inbox": { "name": "Inbox", "file": "inbox.json" },
    "file-manager": { "name": "File Manager", "file": "file-manager.json" },
    "status-board": { "name": "Status Board", "file": "status-board.json" },
    "quick-actions": { "name": "Quick Actions", "file": "quick-actions.json" },
    "changelog": { "name": "Changelog", "file": "changelog.json" },
    "deploy-log": { "name": "Deploy Log", "file": "deploy-log.json", "presets": ["live", "history"] },
    "resource-overview": { "name": "Resource Overview", "file": "resource-overview.json", "presets": ["gauge-grid", "summary-bar"] },
    "service-catalog": { "name": "Service Catalog", "file": "service-catalog.json", "presets": ["grid", "list"] },
    "anatomy-viewer": { "name": "Anatomy Viewer", "file": "anatomy-viewer.json", "presets": ["split"] },
    "ecosystem-grid": { "name": "Ecosystem Grid", "file": "ecosystem-grid.json", "presets": ["standard"] }
  }
}
