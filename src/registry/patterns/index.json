    "stat-card": { "name": "Stat Card", "file": "stat-card.json" },
    "photo-to-recipe": { "name": "Photo to Recipe", "file": "photo-to-recipe.json" },
    "chat-interface": { "name": "Chat Interface", "file": "chat-interface.json" },
    "leaderboard": { "name": "Leaderboard", "file": "leaderboard.json", "presets": ["ranked", "grid", "spotlight"] },
    "announcement-bar": { "name": "Announcement Bar", "file": "announcement-bar.json" },
    "bento-features": { "name": "Bento Features", "file": "bento-features.json", "presets": ["hero-stats", "grid-only"] },
    "logo-strip": { "name": "Logo Strip", "file": "logo-strip.json", "presets": ["static", "marquee"] },
