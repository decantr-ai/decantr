{
  "$schema": "https://decantr.ai/schemas/module.v1.json",
  "module": "decantr/css",
  "description": "Atomic CSS engine + theme management",
  "functions": {
    "css": {
      "params": [
        {
          "name": "classes",
          "type": "...string"
        }
      ],
      "returns": "string"
    },
    "define": {
      "params": [
        {
          "name": "name",
          "type": "string"
        },
        {
          "name": "declaration",
          "type": "string"
        }
      ]
    },
    "sanitize": {
      "params": [
        {
          "name": "str",
          "type": "string"
        }
      ],
      "returns": "string",
      "description": "Sanitizes a string for safe use in HTML attributes. Escapes <, >, \", ', & characters."
    },
    "setStyle": {
      "params": [
        {
          "name": "id",
          "type": "string",
          "description": "Style ID ('clean', 'retro', or custom registered style)"
        }
      ],
      "description": "Set the visual style (personality)."
    },
    "getStyle": {
      "returns": "() => string"
    },
    "getStyleList": {
      "returns": "{ id: string, name: string }[]"
    },
    "registerStyle": {
      "params": [
        {
          "name": "style",
          "type": "Object",
          "description": "Style definition { id, name, seed, personality, typography?, overrides?, components? }"
        }
      ],
      "description": "Register a custom style."
    },
    "setMode": {
      "params": [
        {
          "name": "mode",
          "type": "'light'|'dark'|'auto'"
        }
      ],
      "description": "Set color mode."
    },
    "getMode": {
      "returns": "() => string"
    },
    "getResolvedMode": {
      "returns": "'light'|'dark'"
    },
    "onModeChange": {
      "params": [
        {
          "name": "fn",
          "type": "Function",
          "description": "Callback receiving the new resolved mode ('light'|'dark')"
        }
      ],
      "returns": "Function",
      "description": "Register a callback for mode changes (fires when resolved mode changes)."
    },
    "setTheme": {
      "params": [
        {
          "name": "id",
          "type": "string",
          "description": "Style ID or legacy theme ID"
        },
        {
          "name": "mode='auto'",
          "type": "'light'|'dark'|'auto'",
          "optional": true,
          "description": "Color mode"
        }
      ],
      "description": "Set theme — convenience API combining setStyle + setMode."
    },
    "getTheme": {
      "returns": "() => string"
    },
    "getThemeMeta": {
      "returns": "{ isDark: boolean, style: string, mode: string, resolvedMode: string }",
      "description": "Get metadata about current style + mode."
    },
    "getThemeList": {
      "returns": "{ id: string, name: string }[]"
    },
    "registerTheme": {
      "params": [
        {
          "name": "theme",
          "type": "Object",
          "description": "Old theme object or new style object"
        }
      ],
      "description": "Legacy registerTheme — wraps registerStyle."
    },
    "setShape": {
      "params": [
        {
          "name": "shape",
          "type": "string|null",
          "description": "'sharp', 'rounded', 'pill', or null for style default"
        }
      ],
      "description": "Set the shape (border-radius preset), independent of style."
    },
    "getShape": {
      "returns": "() => string|null"
    },
    "getShapeList": {
      "returns": "{ id: string, label: string }[]"
    },
    "setColorblindMode": {
      "params": [
        {
          "name": "type",
          "type": "'off'|'protanopia'|'deuteranopia'|'tritanopia'"
        }
      ],
      "description": "Set colorblind mode. Transforms seed colors and chart palettes for CVD safety. Orthogonal to style × mode × shape — all four axes are independent."
    },
    "getColorblindMode": {
      "returns": "() => string"
    },
    "getActiveCSS": {
      "returns": "string"
    }
  },
  "fieldTokens": {
    "description": "Unified visual system for all form field containers (.d-field base class)",
    "tokens": [
      "--d-field-bg",
      "--d-field-bg-hover",
      "--d-field-bg-disabled",
      "--d-field-bg-readonly",
      "--d-field-border",
      "--d-field-border-hover",
      "--d-field-border-focus",
      "--d-field-border-error",
      "--d-field-border-success",
      "--d-field-border-disabled",
      "--d-field-border-width",
      "--d-field-ring",
      "--d-field-ring-error",
      "--d-field-ring-success",
      "--d-field-radius",
      "--d-field-placeholder"
    ],
    "variants": [
      "d-field-outlined",
      "d-field-filled",
      "d-field-ghost"
    ],
    "states": [
      "hover",
      "focus-within",
      "data-error",
      "data-success",
      "aria-disabled",
      "readonly"
    ]
  },
  "interactiveStateTokens": {
    "description": "Semantic tokens for item hover, selection, and disabled states",
    "tokens": [
      "--d-item-hover-bg",
      "--d-item-active-bg",
      "--d-selected-bg",
      "--d-selected-fg",
      "--d-selected-border",
      "--d-disabled-opacity",
      "--d-disabled-opacity-soft",
      "--d-icon-muted",
      "--d-icon-subtle"
    ]
  },
  "overlayTokens": {
    "description": "Three overlay intensity levels for modal backdrops and scrims",
    "tokens": [
      "--d-overlay",
      "--d-overlay-light",
      "--d-overlay-heavy"
    ]
  },
  "tableTokens": {
    "description": "Semantic tokens for table styling",
    "tokens": [
      "--d-table-stripe-bg",
      "--d-table-header-bg",
      "--d-table-hover-bg",
      "--d-table-selected-bg"
    ]
  },
  "scrollbarTokens": {
    "description": "Custom scrollbar styling tokens",
    "tokens": [
      "--d-scrollbar-w",
      "--d-scrollbar-track",
      "--d-scrollbar-thumb",
      "--d-scrollbar-thumb-hover"
    ]
  },
  "skeletonTokens": {
    "description": "Skeleton loading state tokens",
    "tokens": [
      "--d-skeleton-bg",
      "--d-skeleton-shine"
    ]
  },
  "layoutTokens": {
    "description": "Layout dimension tokens for content areas, sidebars, drawers, and sheets",
    "tokens": [
      "--d-prose-width",
      "--d-content-width-prose",
      "--d-content-width-standard",
      "--d-sidebar-width-sm",
      "--d-sidebar-width",
      "--d-sidebar-width-lg",
      "--d-drawer-width",
      "--d-sheet-max-h"
    ]
  }
}
