# Decantr Registry Server
# Copy to .env: cp .env.example .env

PORT=3000
BASE_URL=http://localhost:3000
DB_PATH=./data/registry.db
NODE_ENV=development

# GitHub OAuth (https://github.com/organizations/decantr-ai/settings/applications)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# HMAC key for OAuth state (generate: openssl rand -hex 32)
STATE_SECRET=dev-state-secret-change-me

# GitHub user IDs that auto-get admin role (comma-separated)
ADMIN_GITHUB_IDS=
