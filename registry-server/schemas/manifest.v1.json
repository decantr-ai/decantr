{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://registry.decantr.dev/schemas/manifest.v1.json",
  "title": "Decantr Registry Manifest",
  "description": "Tracks installed community content from the Decantr registry.",
  "type": "object",
  "required": ["version", "installed"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "const": "1.0.0"
    },
    "registry": {
      "type": "string",
      "format": "uri",
      "default": "https://registry.decantr.dev/v1"
    },
    "installed": {
      "type": "object",
      "properties": {
        "styles": { "$ref": "#/$defs/contentMap" },
        "recipes": { "$ref": "#/$defs/contentMap" },
        "patterns": { "$ref": "#/$defs/contentMap" },
        "archetypes": { "$ref": "#/$defs/contentMap" },
        "plugins": { "$ref": "#/$defs/contentMap" },
        "templates": { "$ref": "#/$defs/contentMap" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "contentMap": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["version", "source", "installedAt", "checksum", "file"],
        "properties": {
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "source": { "type": "string" },
          "installedAt": { "type": "string", "format": "date-time" },
          "checksum": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "file": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
