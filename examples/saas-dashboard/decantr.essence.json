{
  "version": "2.0.0",
  "archetype": "saas-dashboard",
  "theme": {
    "style": "auradecantism",
    "mode": "dark",
    "recipe": "auradecantism",
    "shape": "rounded"
  },
  "character": ["professional", "data-rich", "tactical"],
  "platform": { "type": "spa", "routing": "hash" },
  "structure": [
    {
      "id": "overview",
      "shell": "sidebar-main",
      "layout": [
        "kpi-grid",
        { "cols": ["activity-feed", "data-table"], "at": "lg" }
      ]
    },
    {
      "id": "analytics",
      "shell": "sidebar-main",
      "layout": [
        "kpi-grid",
        "data-table"
      ]
    },
    {
      "id": "settings",
      "shell": "sidebar-main",
      "layout": [
        { "pattern": "form-sections", "preset": "settings" }
      ]
    }
  ],
  "features": ["auth", "realtime-data"],
  "density": {
    "level": "comfortable",
    "content_gap": "_gap4"
  },
  "guard": {
    "enforce_style": true,
    "enforce_recipe": true,
    "mode": "strict"
  },
  "target": "react",
  "_impression": {
    "vibe": ["professional", "data-rich"],
    "references": [],
    "density_intent": "comfortable",
    "layout_intent": "sidebar-main",
    "novel_elements": []
  }
}
