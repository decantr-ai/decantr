{
  "version": "2.0.0",
  "archetype": "ecommerce",
  "theme": {
    "style": "auradecantism",
    "mode": "light",
    "recipe": "auradecantism",
    "shape": "rounded"
  },
  "character": ["modern", "trustworthy", "clean"],
  "platform": { "type": "spa", "routing": "hash" },
  "structure": [
    {
      "id": "home",
      "shell": "top-nav-main",
      "layout": [
        { "pattern": "hero", "preset": "landing" },
        { "pattern": "card-grid", "preset": "collection", "as": "featured-collections" },
        { "pattern": "card-grid", "preset": "product", "as": "trending-products" },
        "cta-section"
      ]
    },
    {
      "id": "catalog",
      "shell": "top-nav-main",
      "layout": [
        "filter-bar",
        { "pattern": "card-grid", "preset": "product" }
      ]
    },
    {
      "id": "product-detail",
      "shell": "top-nav-main",
      "layout": [
        { "pattern": "detail-header", "preset": "standard" },
        { "pattern": "card-grid", "preset": "product", "as": "related-products" }
      ]
    },
    {
      "id": "cart",
      "shell": "top-nav-main",
      "layout": [
        { "pattern": "data-table", "preset": "standard" },
        "cta-section"
      ]
    }
  ],
  "features": ["auth", "payments", "search"],
  "density": {
    "level": "comfortable",
    "content_gap": "4"
  },
  "guard": {
    "enforce_style": true,
    "enforce_recipe": true,
    "mode": "strict"
  },
  "target": "react"
}
