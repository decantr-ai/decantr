{
  "$schema": "https://decantr.ai/schemas/archetype.v2.json",
  "id": "portfolio",
  "version": "1.0.0",
  "decantr_compat": ">=0.10.0",
  "name": "Portfolio",
  "description": "Personal portfolio for showcasing projects, skills, and professional background",
  "tags": ["portfolio", "creative", "showcase", "personal", "projects"],
  "classification": {
    "triggers": {
      "primary": ["portfolio", "showcase", "personal-site", "creative"],
      "secondary": ["projects", "work", "resume", "freelance", "designer"],
      "negative": []
    },
    "implies": [],
    "weight": 1.0,
    "tier": "core"
  },
  "pages": [
    {
      "id": "home",
      "default_blend": [
        { "pattern": "hero", "preset": "landing" },
        { "pattern": "card-grid", "preset": "content", "as": "featured-projects" },
        "cta-section"
      ],
      "carafe": "top-nav-main"
    },
    {
      "id": "project-detail",
      "default_blend": [
        { "pattern": "detail-header", "preset": "standard" },
        "cta-section"
      ],
      "carafe": "top-nav-main"
    },
    {
      "id": "about",
      "default_blend": [
        { "pattern": "hero", "preset": "split" },
        "activity-feed"
      ],
      "carafe": "top-nav-main"
    },
    {
      "id": "contact",
      "default_blend": [
        { "pattern": "form-sections", "preset": "creation" }
      ],
      "carafe": "top-nav-main"
    }
  ],
  "tannins": ["analytics", "contact-form"],
  "carafes": { "top-nav-main": "Top navigation bar with main content area" },
  "dependencies": {
    "patterns": {
      "hero": "^1.0.0",
      "card-grid": "^1.0.0",
      "cta-section": "^1.0.0",
      "detail-header": "^1.0.0",
      "activity-feed": "^1.0.0",
      "form-sections": "^1.0.0"
    },
    "recipes": {},
    "styles": {}
  },
  "suggested_vintage": { "styles": ["auradecantism", "minimal", "elegant"], "modes": ["light", "auto"] }
}
