{
  "name": "decantr",
  "private": true,
  "description": "Design intelligence layer for AI-generated web applications",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "pnpm -r exec rm -rf dist",
    "cli": "node packages/cli/dist/index.js",
    "mcp": "node packages/mcp-server/dist/index.js",
    "registry:test": "cd apps/registry-server && npm test",
    "registry:dev": "cd apps/registry-server && node src/index.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
