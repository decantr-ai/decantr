{
  "name": "decantr",
  "private": true,
  "description": "Design intelligence layer for AI-generated web applications",
  "license": "MIT",
  "homepage": "https://decantr.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decantr-ai/decantr.git"
  },
  "author": "Decantr AI",
  "scripts": {
    "build:packages": "pnpm --filter @decantr/essence-spec --filter @decantr/registry --filter @decantr/css run build && pnpm --filter @decantr/core --filter @decantr/verifier --filter @decantr/mcp-server --filter @decantr/cli --filter @decantr/vite-plugin run build",
    "build:apps": "pnpm --filter './apps/api' --filter './apps/registry' run build",
    "build": "pnpm run build:packages && pnpm run build:apps",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm --filter './apps/api' typecheck && pnpm --filter './apps/registry' lint",
    "clean": "pnpm -r exec rm -rf dist",
    "mcp": "node packages/mcp-server/dist/index.js",
    "schemas:sync": "node scripts/sync-schema-copies.mjs",
    "audit:docs-marketing": "node scripts/audit-docs-marketing.mjs",
    "audit:package-surface": "node scripts/audit-package-surface.mjs",
    "audit:release-readiness": "node scripts/audit-release-readiness.mjs",
    "audit:release-surface": "node scripts/audit-release-surface.mjs",
    "audit:npm-auth": "node scripts/audit-npm-auth.mjs",
    "audit:npm-surface": "node scripts/audit-npm-surface.mjs",
    "package-surface:sync": "node scripts/sync-package-support-matrix.mjs",
    "npm-surface:normalize:dry-run": "node scripts/normalize-npm-dist-tags.mjs",
    "release:plan": "node scripts/release-plan.mjs",
    "release:graduation-plan": "node scripts/graduation-plan.mjs",
    "release:commands": "node scripts/release-commands.mjs",
    "release:preflight": "node scripts/publish-packages.mjs --publish-dry-run",
    "package:retire:dry-run": "node scripts/deprecate-retired-packages.mjs --dry-run",
    "audit:public-api": "node scripts/audit-public-api.mjs",
    "audit:registry-portal": "node scripts/audit-registry-portal.mjs",
    "audit:registry-dogfood": "pnpm --filter ./apps/registry exec node ../../packages/cli/dist/index.js audit",
    "audit:blueprint-matrix": "pnpm --filter @decantr/essence-spec --filter @decantr/registry --filter @decantr/core --filter @decantr/cli build && node scripts/audit-blueprint-matrix.mjs",
    "showcase:build": "node scripts/build-showcases.mjs",
    "showcase:build:shortlist": "SHOWCASE_GOLDEN_ONLY=1 node scripts/build-showcases.mjs",
    "showcase:copy": "node scripts/copy-showcase-dist.mjs",
    "showcase:copy:shortlist": "SHOWCASE_GOLDEN_ONLY=1 node scripts/copy-showcase-dist.mjs",
    "showcase:validate": "node scripts/validate-showcase-manifest.mjs",
    "showcase:audit": "node scripts/audit-showcases.mjs",
    "showcase:shortlist": "node scripts/shortlist-showcases.mjs",
    "showcase:verify:shortlist": "tsx scripts/verify-showcase-shortlist.ts",
    "showcase": "pnpm run showcase:build && pnpm run showcase:copy",
    "npm-surface:normalize": "node scripts/normalize-npm-dist-tags.mjs --write"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": "8.4.0",
      "vite": "6.4.2"
    }
  },
  "version": "0.0.1"
}
